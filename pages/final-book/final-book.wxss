/* ============================================================
   final-book 最终确认（第 2 步）
   主色 #F9E12A  主字 #000000  次字 #999999  浅线 #EAEAEA
   顶部导航走 app.wxss 全局，此处仅设黄底融合 Hero
   ============================================================ */

.fb-page {
  min-height: 100vh;
  background: #f5f5f5;
  box-sizing: border-box;
}

.global-top-bar {
  background: #F9E12A;
  border-bottom: none;
  box-shadow: none;
}
.global-top-capsule {
  background: rgba(255, 255, 255, 0.55);
  border: 1rpx solid rgba(17, 17, 17, 0.10);
}

.fb-scroll {
  margin-top: calc(212rpx + constant(safe-area-inset-top));
  margin-top: calc(212rpx + env(safe-area-inset-top));
  height: calc(100vh - 212rpx - constant(safe-area-inset-top));
  height: calc(100vh - 212rpx - env(safe-area-inset-top));
  box-sizing: border-box;
}

.fb-scroll--has-cta {
  padding-bottom: calc(200rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* ---------- Hero ---------- */
.fb-hero {
  background: #F9E12A;
}
.fb-hero-inner {
  padding: 28rpx 40rpx 56rpx;
  box-sizing: border-box;
}

.fb-step-chip {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(17, 17, 17, 0.06);
  font-size: 20rpx;
  font-weight: 500;
  color: #999999;
  letter-spacing: 0.3rpx;
  margin-bottom: 14rpx;
}

.fb-hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #000000;
  line-height: 1.4;
  letter-spacing: -0.5rpx;
}

.fb-hero-desc {
  display: block;
  margin-top: 12rpx;
  max-width: 100%;
  font-size: 26rpx;
  color: rgba(17, 17, 17, 0.55);
  line-height: 1.55;
}

.fb-hero-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.fb-hero-status--draft {
  background: rgba(17, 17, 17, 0.09);
  color: #333333;
  border: 1.5rpx solid rgba(17, 17, 17, 0.14);
}

/* 查看底稿：一行轻提示，非独立厚卡 */
.fb-hero-hint {
  margin: -8rpx 0 20rpx;
  padding: 0 4rpx;
  box-sizing: border-box;
}
.fb-hero-hint-text {
  font-size: 22rpx;
  color: #999999;
  line-height: 34rpx;
}

/* ---------- 内容区 ---------- */
.fb-content {
  background: #f5f5f5;
  padding: 0 40rpx 0;
  overflow: visible;
  box-sizing: border-box;
}

.fb-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 24rpx;
  padding: 28rpx 28rpx 28rpx;
  margin-bottom: 48rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  box-shadow: 0 8rpx 28rpx rgba(17, 17, 17, 0.04);
  box-sizing: border-box;
}

.fb-card--summary {
  margin-top: 0;
}

.fb-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #000000;
  margin-bottom: 22rpx;
  letter-spacing: 0.2rpx;
}

.fb-card-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.fb-dot-sep {
  width: 1rpx;
  height: 22rpx;
  background: #A0A0A0;
  margin: 0 16rpx;
  flex-shrink: 0;
}

/* 订单摘要行 */
.fb-summary-row1 {
  margin-bottom: 12rpx;
}
.fb-summary-row1 .fb-dot-sep {
  display: none;
}
.fb-summary-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  line-height: 1.4;
}
.fb-summary-service {
  margin-left: auto;
  height: 40rpx;
  line-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #111111;
  font-size: 20rpx;
  font-weight: 500;
  color: #ffffff;
}
.fb-summary-row2 {
  margin-bottom: 8rpx;
}
.fb-summary-addr {
  font-size: 24rpx;
  color: #333333;
  line-height: 1.5;
}
.fb-summary-area {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}
.fb-summary-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #000000;
  line-height: 1.4;
}
.fb-summary-date {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
}

/* 现场确认 */
.fb-site-item {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.fb-site-item:first-child {
  padding-top: 0;
}
.fb-site-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}
.fb-site-label {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  flex-shrink: 0;
}
.fb-site-value {
  font-size: 24rpx;
  color: #333333;
  font-weight: 500;
  text-align: right;
  line-height: 1.5;
}

.fb-custom-block {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eaeaea;
}
.fb-subsection-title {
  display: block;
  font-size: 22rpx;
  font-weight: 500;
  color: #999999;
  margin-bottom: 20rpx;
}
.fb-custom-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #333333;
  line-height: 1.6;
}
.fb-custom-item:last-child {
  margin-bottom: 0;
}
.fb-custom-prefix {
  flex-shrink: 0;
  margin-right: 10rpx;
  color: #999999;
}
.fb-custom-text {
  flex: 1;
  color: #333333;
}

/* 服务承诺：紧凑 pill */
.fb-promise-tags {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.fb-promise-pill {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  border: 1rpx solid #eaeaea;
  box-sizing: border-box;
}
.fb-promise-pill-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 500;
  color: #333333;
  padding: 2rpx 0;
  border-left: 4rpx solid #F9E12A;
  padding-left: 10rpx;
  line-height: 1.4;
}
.fb-promise-pill-text {
  flex: 1;
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
}

/* 关键条款摘要 */
.fb-key-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  line-height: 1.55;
}
.fb-key-item:last-child {
  margin-bottom: 0;
}
.fb-key-num {
  flex-shrink: 0;
  width: 36rpx;
  color: #b0b0b0;
  font-weight: 500;
  font-size: 22rpx;
}
.fb-key-text {
  flex: 1;
  color: #333333;
}

/* 底部安全区 + 固定 CTA */
.fb-bottom-safe {
  height: calc(32rpx + constant(safe-area-inset-bottom));
  height: calc(32rpx + env(safe-area-inset-bottom));
}

.fb-page--has-cta .fb-bottom-safe {
  height: calc(24rpx + constant(safe-area-inset-bottom));
  height: calc(24rpx + env(safe-area-inset-bottom));
}

.fb-footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 28rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  border-top: 1rpx solid rgba(17, 17, 17, 0.06);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-sizing: border-box;
  z-index: 100;
}

.fb-footer-btn {
  height: 92rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 0.3rpx;
  box-sizing: border-box;
}

.fb-footer-btn-primary {
  background: #F9E12A;
  color: #000000;
}

.fb-footer-btn-secondary {
  background: #ffffff;
  color: #333333;
  border: 1rpx solid #e8e8e8;
}
