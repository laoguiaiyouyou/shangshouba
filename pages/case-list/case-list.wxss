/* =============================================
   case-list 案例实拍列表页
   主题：黄 #f9e12a / 黑 #000000 / 灰白 #F2F2F7
   风格：扁平 + 轻液态玻璃
   ============================================= */

/* 整页容器 */
.cl-page {
  min-height: 100vh;
  background: #F2F2F7;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* ---- 顶部导航 ---- */
.cl-topbar {
  background: #F2F2F7;
  position: sticky;
  top: 0;
  z-index: 10;
}

.cl-topbar-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  height: 88rpx;
}

.cl-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.cl-back--phantom {
  opacity: 0;
  pointer-events: none;
}

.cl-back-icon {
  font-size: 40rpx;
  line-height: 1;
  color: #000000;
  font-weight: 300;
  margin-top: -2rpx;
}

.cl-brand {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.cl-brand-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #f9e12a;
}

.cl-brand-name {
  font-size: 26rpx;
  line-height: 36rpx;
  font-weight: 500;
  color: #000000;
  letter-spacing: -0.2rpx;
}

/* ---- 分类标题区 ---- */
.cl-hero {
  padding: 20rpx 40rpx 16rpx;
  display: flex;
  flex-direction: column;
}

.cl-hero-sup {
  font-size: 22rpx;
  line-height: 32rpx;
  color: rgba(17, 17, 17, 0.40);
  font-weight: 400;
  letter-spacing: 0.4rpx;
}

.cl-hero-title {
  font-size: 52rpx;
  line-height: 72rpx;
  font-weight: 600;
  color: #000000;
  letter-spacing: -1rpx;
  margin-top: 4rpx;
}

/* ---- Tab 切换栏 ---- */
.cl-tab-bar {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  gap: 12rpx;
  padding: 0 40rpx 20rpx;
  overflow-x: auto;
}

.cl-tab-bar::-webkit-scrollbar {
  display: none;
}

.cl-tab {
  flex-shrink: 0;
  height: 56rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(17, 17, 17, 0.07);
  transition: background 0.15s ease;
}

.cl-tab--active {
  background: #111111;
}

.cl-tab-text {
  font-size: 24rpx;
  line-height: 34rpx;
  font-weight: 500;
  color: #333333;
}

.cl-tab--active .cl-tab-text {
  color: #f9e12a;
}

/* ---- 双列图片列表 ---- */
.cl-scroll {
  flex: 1;
  box-sizing: border-box;
}

.cl-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  padding: 0 40rpx;
  box-sizing: border-box;
}

/* 案例卡片 */
.cl-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 8rpx rgba(17, 17, 17, 0.05);
  box-sizing: border-box;
}

/* 图片容器：固定 3:4 纵向比例 */
.cl-card-img-wrap {
  position: relative;
  width: 100%;
  padding-bottom: 133.33%; /* 3:4 */
  overflow: hidden;
}

.cl-card-img {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: block;
}

/* 占位框（cover 为空时） */
.cl-card-placeholder {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(249, 225, 42, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.80);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cl-card-ph-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.cl-card-ph-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  background: rgba(249, 225, 42, 0.30);
  border: 1.5rpx solid rgba(249, 225, 42, 0.60);
}

.cl-card-ph-label {
  font-size: 20rpx;
  line-height: 28rpx;
  color: rgba(17, 17, 17, 0.38);
  font-weight: 400;
  text-align: center;
}

/* 小区 + 面积 */
.cl-card-meta {
  padding: 14rpx 20rpx 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
}

.cl-card-community {
  font-size: 20rpx;
  line-height: 28rpx;
  color: #333333;
  font-weight: 500;
}

.cl-card-dot {
  font-size: 20rpx;
  color: rgba(17, 17, 17, 0.30);
}

.cl-card-area {
  font-size: 20rpx;
  line-height: 28rpx;
  color: rgba(17, 17, 17, 0.45);
}

/* ---- 底部安全区 ---- */
.cl-bottom-safe {
  height: calc(32rpx + env(safe-area-inset-bottom));
}
