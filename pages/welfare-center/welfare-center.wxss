.welfare-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-top: calc(212rpx + env(safe-area-inset-top) + 20rpx);
  padding-bottom: 80rpx;
}

.welfare-body {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.welfare-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin: 0 40rpx 48rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.welfare-card:last-child {
  margin-bottom: 0;
}

/* =============================
   1. 合并返还主模块：资产区 + 邀请 + 最近邀请目录
============================= */
.rebate-main-card {
  display: flex;
  flex-direction: column;
  padding: 28rpx 28rpx 28rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  box-shadow: none;
}

.asset-grid-wrap {
  position: relative;
  min-height: 100rpx;
}

.asset-grid {
  display: flex;
  align-items: stretch;
}

.asset-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  min-height: 0;
}

.asset-col:first-child {
  padding-right: 56rpx;
}

.asset-col:last-child {
  padding-left: 56rpx;
}

.asset-col .balance-label {
  height: 34rpx;
  line-height: 34rpx;
  margin-bottom: 2rpx;
}

.asset-col .balance-value {
  height: 48rpx;
  line-height: 48rpx;
}

.asset-withdraw-anchor {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

.rebate-divider {
  height: 1rpx;
  background: rgba(17, 17, 17, 0.08);
  margin: 14rpx 0 14rpx;
}

.balance-label {
  font-size: 22rpx;
  color: #999999;
  text-align: center;
  display: block;
  line-height: 34rpx;
}

.balance-value {
  font-size: 40rpx;
  font-weight: 600;
  color: #000000;
  text-align: center;
  display: block;
}

.balance-value.highlight {
  color: #000000;
}


.asset-divider {
  width: 2rpx;
  align-self: stretch;
  background: rgba(17, 17, 17, 0.08);
  flex-shrink: 0;
  margin: 0 12rpx;
}


.balance-action {
  border-radius: 999rpx;
  background: #F9E12A;
}

.balance-action--capsule {
  padding: 8rpx 22rpx;
}

.balance-action-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #000000;
}

.invite-summary {
  padding: 2rpx 4rpx 14rpx;
  text-align: center;
}

.invite-summary-line {
  display: block;
  font-size: 22rpx;
  color: #999999;
  line-height: 36rpx;
}

.invite-summary-line--strong {
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
  line-height: 38rpx;
}

.invite-btn {
  width: 100%;
  background: #F9E12A;
  border-radius: 999rpx;
  text-align: center;
  padding: 20rpx 0;
  box-sizing: border-box;
  margin-bottom: 12rpx;
}

.invite-btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #000000;
}

.record-scroll {
  max-height: 130rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.06);
}

.record-item:last-child {
  border-bottom: none;
}

.record-name {
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 400;
  color: #333333;
  line-height: 36rpx;
  margin-right: 16rpx;
}
.record-mid {
  flex: 1;
  font-size: 22rpx;
  color: #999999;
  line-height: 36rpx;
  min-width: 0;
}
.record-amount {
  flex: 0 0 auto;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  line-height: 36rpx;
}
.record-empty {
  padding: 24rpx 0;
  text-align: center;
}

.record-empty-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 36rpx;
}
/* =============================
   2. 我的权益：无外层白卡，灰底上标题 + 两入口
============================= */
.equity-section {
  margin: 0 40rpx 48rpx;
  padding: 0 6rpx;
  box-sizing: border-box;
}

.equity-title {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #999999;
  line-height: 34rpx;
  margin-bottom: 12rpx;
}

.equity-row {
  display: flex;
  gap: 12rpx;
}

.equity-entry {
  flex: 1;
  padding: 28rpx 28rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.05);
  border-radius: 24rpx;
  background: #fcfcfc;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.equity-entry-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  line-height: 36rpx;
}

.equity-entry-desc {
  font-size: 22rpx;
  color: #999999;
  line-height: 34rpx;
}

/* =============================
   3. 选择返还方式弹层
============================= */
.mode-sheet-root {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1001;
  pointer-events: none;
}

.mode-sheet-root .mode-sheet-mask,
.mode-sheet-root .mode-sheet-panel {
  pointer-events: auto;
}

.mode-sheet-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
}

.mode-sheet-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx 32rpx calc(28rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  box-sizing: border-box;
}

.mode-sheet-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #000000;
  line-height: 42rpx;
  margin-bottom: 18rpx;
}

.mode-option {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  background: #fafafa;
}

/* 模式卡：未选 / 已选定 / 互斥失效 / 已兑现（预留）；不因户数锁「不可选」 */
.mode-option--unselected {
  opacity: 1;
}

.mode-option--selected {
  opacity: 1;
  border-color: rgba(249, 225, 42, 0.85);
  background: rgba(249, 225, 42, 0.12);
}

.mode-option--mutex {
  opacity: 0.38;
}

.mode-option--settled {
  opacity: 0.42;
}

.mode-row {
  display: flex;
}

.mode-row--dual {
  gap: 12rpx;
}

.mode-row--dual .mode-option--single {
  flex: 1;
  min-width: 0;
}

.mode-row--single {
  margin-top: 16rpx;
}

.mode-option--single {
  flex: 1;
}

.mode-addon-card {
  width: 100%;
  padding: 18rpx 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  background: #fafafa;
  box-sizing: border-box;
}

.mode-addon-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  line-height: 36rpx;
  margin-bottom: 6rpx;
}

.mode-addon-sub {
  display: block;
  font-size: 22rpx;
  color: #999999;
  line-height: 34rpx;
}

.mode-radio {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  box-sizing: border-box;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.mode-radio--on {
  background: #F9E12A;
  border: none;
}

.mode-radio--off {
  background: transparent;
  border: 2rpx solid #cccccc;
}

.mode-option-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.mode-option-main {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  line-height: 36rpx;
}

.mode-option-sub {
  font-size: 22rpx;
  color: #999999;
  line-height: 34rpx;
}

.mode-sheet-note {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #999999;
  line-height: 34rpx;
}

.mode-sheet-footer {
  margin-top: 22rpx;
}

.mode-btn {
  width: 100%;
  border-radius: 999rpx;
  text-align: center;
  padding: 22rpx 0;
}

.mode-btn--primary {
  background: #F9E12A;
}

.mode-btn--secondary {
  margin-top: 16rpx;
  background: transparent;
  border: 1rpx solid rgba(17, 17, 17, 0.12);
}

.mode-btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #000000;
  line-height: 32rpx;
}

.mode-btn-text--secondary {
  color: #333333;
}
