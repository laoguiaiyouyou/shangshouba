/* ================================================================
   detail — Pristine Canvas Editorial Design
   ──────────────────────────────────────────
   Base bg: #f9f9f9 | Cards: #ffffff | Accent: #F9E12A
   Radius: 24rpx | Padding: 28rpx | Side margin: 40rpx
   Section gap: 48-64rpx | Max font-weight: 600
   ================================================================ */

/* ── Page root ── */
.detail-page {
  min-height: 100vh;
  background: #f9f9f9;
  box-sizing: border-box;
}

/* ── Top bar: transparent over hero ── */
.detail-page .detail-top-bar {
  background: transparent;
  border-bottom: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.detail-page .detail-top-bar .global-top-back-icon,
.detail-page .detail-top-bar .global-brand-title {
  color: #ffffff;
}

.detail-page .detail-top-bar .global-brand-dot {
  background: #ffffff;
}


/* ================================================================
   1. Hero Section — photo-based
   ================================================================ */
.dt-hero {
  position: relative;
  width: 100%;
  height: 680rpx;
  overflow: hidden;
}

.dt-hero-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: #888888;
}

.dt-hero-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.35);
}

.dt-hero-content {
  position: absolute;
  left: 40rpx;
  bottom: 60rpx;
  right: 40rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
}

.dt-hero-label {
  display: block;
  font-size: 20rpx;
  line-height: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.dt-hero-title {
  display: block;
  font-size: 44rpx;
  line-height: 60rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.dt-hero-subtitle {
  display: block;
  font-size: 24rpx;
  line-height: 36rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.9);
}


/* ================================================================
   2. Guard-level Progress Card
   ================================================================ */
.dt-progress-card {
  position: relative;
  margin: -48rpx 40rpx 0;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx 24rpx 24rpx 24rpx;
  box-sizing: border-box;
  z-index: 3;
}

/* Shared section head: yellow accent bar + title */
.dt-section-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 24rpx;
}

.dt-accent-bar {
  flex-shrink: 0;
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
  background: #F9E12A;
  margin-right: 14rpx;
}

.dt-section-title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
  color: #000000;
}

.dt-phase-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.dt-phase {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
}

.dt-phase-num {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #000000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dt-phase-num-text {
  font-size: 24rpx;
  line-height: 1;
  font-weight: 500;
  color: #ffffff;
}

.dt-phase-body {
  flex: 1;
  min-width: 0;
  padding-top: 4rpx;
}

.dt-phase-visit {
  display: block;
  font-size: 20rpx;
  font-weight: 400;
  color: #999999;
  line-height: 28rpx;
  letter-spacing: 0.5rpx;
  margin-bottom: 2rpx;
}
.dt-phase-title {
  display: block;
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  color: #000000;
}

.dt-phase-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 34rpx;
  font-weight: 400;
  color: #999999;
}


/* ================================================================
   3. Recording Section
   ================================================================ */
.dt-recording {
  margin: 48rpx 40rpx 0;
}

.dt-recording-inner {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #666666;
}

.dt-recording-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: #555555;
}

.dt-recording-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.45);
}

.dt-recording-content {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.dt-recording-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.dt-recording-title {
  display: block;
  font-size: 36rpx;
  line-height: 50rpx;
  font-weight: 600;
  color: #ffffff;
  text-align: center;
  margin-bottom: 12rpx;
}

.dt-recording-desc {
  display: block;
  font-size: 22rpx;
  line-height: 34rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
}


/* ================================================================
   4. Safety Section
   ================================================================ */
.dt-safety {
  margin: 48rpx 40rpx 0;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.dt-safety-body {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.dt-safety-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dt-safety-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.dt-safety-mark {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1;
}

.dt-safety-mark--x {
  background: #f2f2f2;
  color: #999999;
}

.dt-safety-mark--check {
  background: #F9E12A;
  color: #000000;
}

.dt-safety-text {
  font-size: 26rpx;
  line-height: 40rpx;
  font-weight: 400;
  color: #333333;
}

.dt-safety-photo {
  flex-shrink: 0;
  width: 240rpx;
}

.dt-safety-photo-placeholder {
  width: 100%;
  height: 280rpx;
  border-radius: 16rpx;
  background: #e8e8e8;
}


/* ================================================================
   5. Comparison Table
   ================================================================ */
.dt-compare {
  margin: 64rpx 40rpx 0;
}

.dt-compare-heading {
  display: block;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 500;
  color: #000000;
  text-align: center;
  margin-bottom: 24rpx;
}

.dt-compare-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 0;
  overflow: hidden;
  box-sizing: border-box;
}

.dt-compare-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
}

.dt-compare-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 18rpx 24rpx;
  box-sizing: border-box;
}

.dt-compare-row + .dt-compare-row {
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.dt-compare-col {
  font-size: 24rpx;
  line-height: 36rpx;
  font-weight: 400;
}

.dt-compare-col--dim {
  flex: 1;
  text-align: center;
  color: #999999;
  font-weight: 400;
}

.dt-compare-col--ours {
  flex: 1;
  text-align: center;
  font-weight: 500;
  color: #000000;
}

.dt-compare-col--old {
  flex: 1;
  text-align: center;
  color: #999999;
  font-weight: 400;
}

.dt-compare-header .dt-compare-col--dim {
  font-size: 22rpx;
  font-weight: 400;
  color: #999999;
}

.dt-compare-header .dt-compare-col--ours {
  font-size: 22rpx;
  font-weight: 500;
  color: #000000;
}

.dt-compare-header .dt-compare-col--old {
  font-size: 22rpx;
  font-weight: 400;
  color: #999999;
}


/* ================================================================
   6. Commitment Black Card
   ================================================================ */
.dt-commit {
  margin: 48rpx 40rpx 0;
}

.dt-commit-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  background: #111111;
  border-radius: 24rpx;
  box-sizing: border-box;
}

.dt-commit-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.dt-commit-badge {
  display: inline-block;
  align-self: flex-start;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  background: #F9E12A;
  font-size: 18rpx;
  line-height: 28rpx;
  font-weight: 500;
  color: #000000;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.dt-commit-title {
  display: block;
  font-size: 32rpx;
  line-height: 46rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.dt-commit-desc {
  display: block;
  font-size: 22rpx;
  line-height: 34rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.75);
}

.dt-commit-photo {
  flex-shrink: 0;
  width: 200rpx;
}

.dt-commit-photo-placeholder {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
  background: #333333;
}


/* ================================================================
   7. Certified Cleaner
   ================================================================ */
.dt-certified {
  margin: 48rpx 40rpx 0;
  padding: 40rpx 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dt-certified-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid #F9E12A;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-sizing: border-box;
}

.dt-certified-avatar-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #e8e8e8;
}

.dt-certified-badge {
  display: inline-block;
  padding: 4rpx 20rpx;
  border-radius: 8rpx;
  background: #F9E12A;
  font-size: 18rpx;
  line-height: 28rpx;
  font-weight: 500;
  color: #000000;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.dt-certified-title {
  display: block;
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 500;
  color: #000000;
  margin-bottom: 16rpx;
}

.dt-certified-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
}

.dt-certified-tag {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
  font-size: 22rpx;
  line-height: 32rpx;
  font-weight: 400;
  color: #999999;
}


/* ================================================================
   8. Service List Section
   ================================================================ */
.dt-svc-section {
  margin: 64rpx 40rpx 0;
}

/* svc-module: reset for Pristine theme */
.svc-module {
  padding: 0;
  margin-top: 0;
}

.svc-module-head {
  display: none;
}

.svc-group {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.svc-group:first-of-type {
  margin-top: 0;
}

.svc-group-bar {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  background: #111111;
  border-radius: 0;
  overflow: hidden;
}

.svc-group-bar-accent {
  width: 0;
  flex-shrink: 0;
}

.svc-group-bar-inner {
  flex: 1;
  padding: 14rpx 20rpx;
  box-sizing: border-box;
}

.svc-group-title-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 0 12rpx;
}

.svc-group-name {
  display: block;
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 500;
  color: #F9E12A;
}

.svc-group-title-row .svc-group-name {
  flex-shrink: 0;
}

.svc-group-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 32rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.60);
}

.svc-group-title-row .svc-group-sub {
  display: inline-block;
  margin-top: 0;
}

.svc-group-hint {
  display: block;
  margin: 10rpx 0 4rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 22rpx;
  line-height: 32rpx;
  font-weight: 500;
  color: #999999;
}

.svc-line {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 16rpx 10rpx 20rpx;
  box-sizing: border-box;
  background: #ffffff;
}

.svc-line + .svc-line {
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.svc-line--has-pill {
  padding-top: 13rpx;
  padding-bottom: 13rpx;
  align-items: flex-start;
}

.svc-line-main {
  flex: 1;
  min-width: 0;
}

.svc-line-text-wrap {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: baseline;
}

.svc-seg {
  font-size: 24rpx;
  line-height: 36rpx;
  color: #333333;
  font-weight: 400;
}

.svc-seg--hl {
  font-size: 24rpx;
  line-height: 36rpx;
  color: #333333;
  font-weight: 500;
}

.svc-suffix-tag {
  margin-left: 8rpx;
  padding: 2rpx 10rpx;
  font-size: 20rpx;
  line-height: 30rpx;
  font-weight: 500;
  color: #000000;
  background: rgba(249, 225, 42, 0.45);
  border-radius: 8rpx;
}

.svc-line-pill {
  margin-top: 8rpx;
  margin-left: 0;
  padding: 8rpx 16rpx;
  align-self: flex-start;
  border-radius: 999rpx;
  background: rgba(249, 225, 42, 0.45);
  box-sizing: border-box;
}

.svc-line-pill-text {
  font-size: 20rpx;
  line-height: 30rpx;
  font-weight: 500;
  color: #333333;
}

.svc-line-dot-wrap {
  flex-shrink: 0;
  width: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
}

.svc-line-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #111111;
}


/* ================================================================
   9. Pricing Section (preserved structure, Pristine theme)
   ================================================================ */
.detail-bottom-zone {
  box-sizing: border-box;
}

.detail-bottom-zone--preview {
  margin: 64rpx 40rpx 0;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

/* Invite strip */
.detail-invite-strip {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  box-sizing: border-box;
}

.detail-invite-icon {
  font-size: 26rpx;
  line-height: 1;
}

.detail-invite-text {
  font-size: 24rpx;
  line-height: 34rpx;
  color: #333333;
  font-weight: 500;
}

/* Main price card */
.price-main-card {
  background: #111111;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.price-main-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.price-main-row--low {
  margin-top: 10rpx;
}

.price-main-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.price-main-val {
  font-size: 44rpx;
  font-weight: 600;
  color: #ffffff;
}

.price-main-val--low {
  color: #F9E12A;
}

.price-main-unit {
  font-size: 24rpx;
  font-weight: 500;
}

.price-main-note {
  display: block;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
  font-size: 22rpx;
  line-height: 32rpx;
  color: rgba(255, 255, 255, 0.45);
  text-align: center;
}

/* Save pick */
.save-pick {
  margin-bottom: 16rpx;
}

.save-pick-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #000000;
  line-height: 40rpx;
  margin-bottom: 14rpx;
}

.save-pick-hint {
  font-size: 22rpx;
  font-weight: 500;
  color: #999999;
  margin-left: 8rpx;
}

.save-pick-options {
  display: flex;
  gap: 12rpx;
}

.save-pick-opt {
  flex: 1;
  background: #f9f9f9;
  border-radius: 18rpx;
  padding: 20rpx 18rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  transition: border-color 0.15s;
}

.save-pick-opt--on {
  border-color: #111111;
  box-shadow: 0 0 0 2rpx #111111;
}

.save-pick-opt-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  line-height: 36rpx;
}

.save-pick-opt-val {
  font-size: 34rpx;
  font-weight: 600;
  color: #000000;
  line-height: 42rpx;
}

.save-pick-opt--on .save-pick-opt-val {
  color: #000000;
}

.save-pick-opt-cond {
  font-size: 21rpx;
  color: #999999;
  line-height: 30rpx;
  margin-top: 2rpx;
}

.save-pick-opt--pending {
  border-style: dashed;
  border-color: rgba(0, 0, 0, 0.12);
  background: #fafafa;
}

.save-pick-opt--disabled {
  opacity: 0.5;
  pointer-events: none;
  background: #f5f5f5;
}

.save-pick-opt-val--muted {
  color: #cccccc;
  font-weight: 600;
  font-size: 30rpx;
}

.save-pick-opt-status {
  font-size: 20rpx;
  line-height: 28rpx;
  font-weight: 500;
  color: #999999;
  margin-top: 4rpx;
}

.save-pick-opt-status--ok {
  color: #333333;
}

/* State blocks */
.save-pick-opt-state {
  margin-top: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
}

.save-pick-opt-state--pending {
  background: rgba(249, 225, 42, 0.1);
}

.save-pick-opt-state--disabled {
  background: rgba(0, 0, 0, 0.04);
}

.save-pick-opt-state--ok {
  background: rgba(249, 225, 42, 0.1);
}

.save-pick-opt-state-label {
  display: block;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 30rpx;
}

.save-pick-opt-state--pending .save-pick-opt-state-label {
  color: #333333;
}

.save-pick-opt-state--disabled .save-pick-opt-state-label {
  color: #000000;
}

.save-pick-opt-state--ok .save-pick-opt-state-label {
  color: #333333;
}

.save-pick-opt-state-desc {
  display: block;
  font-size: 20rpx;
  line-height: 30rpx;
  color: #999999;
  margin-top: 2rpx;
}

/* Path hint */
.save-path-hint {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.save-path-hint-text {
  display: block;
  font-size: 23rpx;
  line-height: 34rpx;
  color: #333333;
}

/* Main preview button */
.preview-main-btn {
  width: 100%;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #F9E12A;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-main-btn-text {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  color: #000000;
}


/* ================================================================
   10. Floor wax modal (preserved)
   ================================================================ */
.svc-floor-wax-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.svc-floor-wax-dialog {
  width: 100%;
  max-width: 620rpx;
  padding: 36rpx 32rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.svc-floor-wax-dialog-title {
  display: block;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 600;
  color: #000000;
  text-align: center;
  margin-bottom: 20rpx;
}

.svc-floor-wax-dialog-body {
  display: block;
  font-size: 26rpx;
  line-height: 40rpx;
  color: #333333;
  margin-bottom: 28rpx;
}

.svc-floor-wax-dialog-btn {
  padding: 20rpx;
  border-radius: 24rpx;
  background: #F9E12A;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.svc-floor-wax-dialog-btn-text {
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 500;
  color: #000000;
}

/* ── 邀约弹窗 ── */
.inv-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.inv-dialog {
  width: 100%;
  max-width: 620rpx;
  padding: 40rpx 32rpx 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.inv-title {
  display: block;
  font-size: 36rpx;
  line-height: 50rpx;
  font-weight: 600;
  color: #000000;
  text-align: center;
  margin-bottom: 16rpx;
}

.inv-desc {
  display: block;
  font-size: 28rpx;
  line-height: 42rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 32rpx;
}

.inv-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.inv-btn {
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.inv-btn--primary {
  background: #F9E12A;
}

.inv-btn--secondary {
  background: #ffffff;
  border: 2rpx solid #000000;
}

.inv-btn-text {
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 600;
  color: #000000;
}

.inv-hint {
  display: block;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #999999;
  text-align: center;
  margin-top: 20rpx;
}

/* ── 服务清单卡片式 ── */
.dt-svc-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.dt-svc-head-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #000000;
}
.dt-svc-head-meta {
  font-size: 18rpx;
  font-weight: 400;
  color: #CCCCCC;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}
.dt-svc-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.dt-svc-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
}
.dt-svc-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #000000;
  line-height: 40rpx;
  margin-bottom: 16rpx;
}
.dt-svc-card-items {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.dt-svc-card-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}
.dt-svc-check-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #000000;
  flex-shrink: 0;
  margin-top: 6rpx;
  position: relative;
}
.dt-svc-check-icon::after {
  content: '✓';
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  color: #ffffff;
  font-weight: 500;
}
.dt-svc-card-item-text {
  font-size: 24rpx;
  font-weight: 400;
  color: #999999;
  line-height: 38rpx;
}

/* ── 价格详情 ── */
.dt-price-section {
  margin: 40rpx 40rpx 0;
  padding: 32rpx;
  background: #f3f3f3;
  border-radius: 24rpx;
}
.dt-price-section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #000000;
  line-height: 42rpx;
  margin-bottom: 28rpx;
}
.dt-price-lines {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-bottom: 28rpx;
}
.dt-price-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.dt-price-line-name-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.dt-price-line-name {
  font-size: 24rpx;
  font-weight: 400;
  color: #999999;
  line-height: 36rpx;
}
.dt-price-line-val {
  font-size: 24rpx;
  font-weight: 500;
  color: #000000;
  line-height: 36rpx;
}
.dt-price-line-off {
  font-size: 24rpx;
  font-weight: 500;
  color: #000000;
  line-height: 36rpx;
}
.dt-price-divider {
  height: 0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
  margin: 4rpx 0 20rpx;
}
.dt-price-final {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}
.dt-price-final-left {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}
.dt-price-final-en {
  font-size: 16rpx;
  font-weight: 400;
  color: #CCCCCC;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}
.dt-price-final-label {
  font-size: 22rpx;
  font-weight: 400;
  color: #999999;
}
.dt-price-final-right {
  display: flex;
  align-items: baseline;
}
.dt-price-final-num {
  font-size: 52rpx;
  font-weight: 600;
  color: #000000;
  line-height: 56rpx;
  letter-spacing: -1rpx;
}
.dt-price-final-unit {
  font-size: 24rpx;
  font-weight: 500;
  color: #999999;
  margin-left: 4rpx;
}

/* ── 其他优惠 ── */
.dt-qualify-section {
  margin: 40rpx 40rpx 0;
}
.dt-qualify-head {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  margin-bottom: 24rpx;
}
.dt-qualify-title-en {
  font-size: 32rpx;
  font-weight: 500;
  color: #000000;
  line-height: 44rpx;
}
.dt-qualify-title-cn {
  font-size: 24rpx;
  font-weight: 400;
  color: #999999;
  line-height: 34rpx;
}
.dt-qualify-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 单张优惠卡 */
.dt-qc {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #ffffff;
  border: 2rpx solid transparent;
  border-radius: 20rpx;
  gap: 16rpx;
}
.dt-qc--on {
  border-color: #000000;
}

/* 左侧图标方块 */
.dt-qc-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #f3f3f3;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.dt-qc-icon-box--on {
  background: #F9E12A;
}
.dt-qc-icon-glyph {
  font-size: 28rpx;
  color: #000000;
  font-weight: 500;
}

/* 中间文字 */
.dt-qc-info {
  flex: 1;
  min-width: 0;
}
.dt-qc-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #000000;
  line-height: 36rpx;
}
.dt-qc-sub {
  display: block;
  font-size: 20rpx;
  font-weight: 400;
  color: #999999;
  line-height: 28rpx;
  margin-top: 2rpx;
}

/* 右侧价格+radio */
.dt-qc-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}
.dt-qc-price {
  padding: 4rpx 16rpx;
  background: #e8e8e8;
  border-radius: 12rpx;
  min-width: 100rpx;
  text-align: center;
}
.dt-qc-price--on {
  background: #F9E12A;
}
.dt-qc-price-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #000000;
}
.dt-qc-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #CCCCCC;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.dt-qc-radio--on {
  border-color: #000000;
}
.dt-qc-radio-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #000000;
}

/* ── 价格透明保障 ── */
.dt-trust-card {
  margin: 48rpx 40rpx 0;
  padding: 28rpx;
  background: #f3f3f3;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.dt-trust-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #000000;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.dt-trust-circle-icon {
  font-size: 28rpx;
  color: #F9E12A;
}
.dt-trust-body {
  flex: 1;
}
.dt-trust-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #000000;
  line-height: 36rpx;
}
.dt-trust-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 20rpx;
  font-weight: 400;
  color: #999999;
  line-height: 32rpx;
}

/* ================================================================
   11. Bottom CTA (floating with shadow)
   ================================================================ */
.dt-bottom-cta {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 90;
}
.dt-bottom-cta-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 20rpx;
  background: #F9E12A;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(249, 225, 42, 0.35), 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
.dt-bottom-cta-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #000000;
}

/* ── 推荐二维码弹窗 ── */
.rec-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
}
.rec-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 0 32rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 101;
  box-sizing: border-box;
  text-align: center;
}
.rec-handle {
  width: 60rpx;
  height: 6rpx;
  background: #C6C6C8;
  border-radius: 3rpx;
  margin: 16rpx auto 24rpx;
}
.rec-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 8rpx;
}
.rec-desc {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 32rpx;
}
.rec-qr-box {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 24rpx;
}
.rec-qr-img {
  width: 360rpx;
  height: 360rpx;
}
.rec-qr-loading {
  font-size: 26rpx;
  color: #999999;
}
.rec-hint {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

/* Bottom spacer for fixed CTA clearance */
.dt-bottom-spacer,
.dt-spacer {
  height: calc(140rpx + env(safe-area-inset-bottom));
}
.dt-spacer-sm {
  height: calc(96rpx + env(safe-area-inset-bottom) + 24rpx);
}
