/* 主黄 #F9E12A + 黑白灰；玻璃感仅大容器 */
.cl-page {
  min-height: 100vh;
  padding: 24rpx 40rpx 64rpx;
  box-sizing: border-box;
  background: #f5f5f5;
}

.cl-shell {
  border-radius: 24rpx;
  padding: 28rpx 28rpx 32rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  box-sizing: border-box;
}

/* 概览 */
.cl-overview {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0 24rpx;
  border-bottom: 1rpx solid rgba(17, 17, 17, 0.06);
}

.cl-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.cl-stat-num {
  font-size: 36rpx;
  font-weight: 600;
  color: #000000;
  line-height: 44rpx;
}

.cl-stat-num--warn {
  color: #F9E12A;
}

.cl-stat-num--muted {
  color: #bbbbbb;
}

.cl-stat-label {
  font-size: 22rpx;
  color: #999999;
  line-height: 34rpx;
}

/* 空状态 */
.cl-empty {
  padding: 80rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.cl-empty-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #000000;
  line-height: 42rpx;
  margin-bottom: 12rpx;
}

.cl-empty-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 38rpx;
  margin-bottom: 36rpx;
}

.cl-empty-btn {
  padding: 18rpx 40rpx;
  border-radius: 999rpx;
  background: #f9e12a;
}

.cl-empty-btn-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #000000;
}

/* 列表 */
.cl-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 20rpx;
}

.cl-card {
  display: flex;
  align-items: stretch;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(17, 17, 17, 0.06);
  overflow: hidden;
}

.cl-card--dim {
  opacity: 0.5;
}

.cl-card--highlight {
  border-color: #f9e12a;
  box-shadow: 0 0 0 2rpx rgba(249, 225, 42, 0.5);
}

/* 左侧金额区 */
.cl-card-left {
  width: 160rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 16rpx;
  background: rgba(249, 225, 42, 0.12);
  border-right: 1rpx dashed rgba(17, 17, 17, 0.1);
  gap: 8rpx;
}

.cl-benefit {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
  line-height: 38rpx;
  text-align: center;
}

.cl-threshold {
  font-size: 20rpx;
  color: #999999;
  line-height: 30rpx;
  text-align: center;
}

/* 右侧信息区 */
.cl-card-right {
  flex: 1;
  padding: 28rpx 28rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.cl-card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.cl-card-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #000000;
  line-height: 36rpx;
  flex: 1;
  min-width: 0;
}

.cl-status-tag {
  flex-shrink: 0;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.cl-status-tag--warn {
  background: rgba(249, 225, 42, 0.1);
}

.cl-status-tag--muted {
  background: rgba(17, 17, 17, 0.06);
}

.cl-status-tag-text {
  font-size: 20rpx;
  color: #999999;
  line-height: 30rpx;
}

.cl-status-tag--warn .cl-status-tag-text {
  color: #F9E12A;
}

.cl-scope,
.cl-source,
.cl-expire {
  font-size: 22rpx;
  color: #999999;
  line-height: 34rpx;
}

.cl-btn {
  margin-top: 12rpx;
  padding: 14rpx 0;
  border-radius: 999rpx;
  background: #f9e12a;
  text-align: center;
}

.cl-btn--disabled {
  background: #eeeeee;
}

.cl-btn-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #000000;
}

.cl-btn--disabled .cl-btn-text {
  color: #bbbbbb;
}

/* 去使用弹层 */
.cl-modal-root {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1000;
}

.cl-modal-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
}

.cl-modal-box {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 28rpx 32rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.cl-modal-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #000000;
  line-height: 40rpx;
  margin-bottom: 8rpx;
}

.cl-modal-benefit {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #000000;
  line-height: 52rpx;
  margin-bottom: 20rpx;
}

.cl-modal-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 28rpx;
}

.cl-modal-info-line {
  font-size: 26rpx;
  color: #999999;
  line-height: 38rpx;
}

.cl-modal-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.cl-modal-btn {
  width: 100%;
  padding: 22rpx 0;
  border-radius: 999rpx;
  text-align: center;
  box-sizing: border-box;
}

.cl-modal-btn--primary {
  background: #f9e12a;
}

.cl-modal-btn--ghost {
  border: 1rpx solid rgba(17, 17, 17, 0.12);
}

.cl-modal-btn-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #000000;
}

.cl-ghost-text {
  font-weight: 500;
}
