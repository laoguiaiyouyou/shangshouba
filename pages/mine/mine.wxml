<view class="mine-page">

  <view class="global-top-bar">
    <view class="global-brand-wrap">
      <view class="global-brand-dot"></view>
      <text class="global-brand-title">安心住·上手吧</text>
    </view>
    <view class="global-top-capsule"></view>
  </view>

  <view class="mine-content">

    <!-- 用户主卡 -->
    <view class="mine-hero-card">

      <view class="mine-user-identity">
        <view class="user-avatar"></view>
        <view class="mine-user-info">
          <text class="user-name">我的信息</text>
          <view class="user-label-row">
            <text class="user-label">安心住 · 服务用户</text>
            <view class="user-leader-badge" bindtap="goGroupBuyTab">
              <text class="user-leader-badge-text">{{leaderLevelLabel}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="hero-metrics">
        <view class="hero-metric hero-metric--pending">
          <text class="hero-metric-label">待激活</text>
          <text class="hero-metric-value">{{pendingDisplay}}</text>
          <text class="hero-metric-desc">邻居完工后激活</text>
        </view>
        <view class="hero-metric hero-metric--withdraw">
          <text class="hero-metric-label hero-metric-label--light">推荐返现</text>
          <text class="hero-metric-value hero-metric-value--yellow">{{cashDisplay}}</text>
          <view class="hero-withdraw-btn" bindtap="goWithdraw">
            <text class="hero-withdraw-btn-text">提现</text>
          </view>
        </view>
      </view>

      <!-- 我的开团：一行轻量入口 -->
      <view class="mine-group-entry" bindtap="goInviteCenter">
        <text class="mine-group-entry-text">我的开团</text>
        <text class="mine-group-entry-hint" wx:if="{{leaderProgressHint}}">{{leaderProgressHint}}</text>
        <text class="mine-group-entry-arrow">›</text>
      </view>

      <!-- 我的券 -->
      <view class="mine-group-entry" bindtap="goMyCoupons">
        <text class="mine-group-entry-text">我的券</text>
        <text class="mine-group-entry-hint" wx:if="{{myCouponCount > 0}}">{{myCouponCount}} 张可用</text>
        <text class="mine-group-entry-arrow">›</text>
      </view>


    </view>

    <!-- ─── 我的订单 ─── -->
    <view class="mine-section mine-order-section">

      <view class="section-head" bindlongpress="onClearDemoPlan">
        <text class="section-title">我的订单</text>
      </view>

      <view wx:if="{{orderDisplayList.length > 0}}" class="order-list-wrap">
        <scroll-view class="order-scroll" scroll-y="true" show-scrollbar="{{false}}">
          <view class="order-item" wx:for="{{orderDisplayList}}" wx:key="index"
            bindtap="handleOrderItemTap"
            bindlongpress="onOrderLongPress"
            data-index="{{index}}"
            data-orderid="{{item.orderId}}"
            data-ordertype="{{item.orderType}}"
            data-name="{{item.name}}"
            data-sub="{{item.sub}}"
            data-status="{{item.status}}"
            data-invitecode="{{item.inviteCode}}"
            data-community="{{item.communityName}}"
            data-roomno="{{item.roomNo}}"
            data-orderarea="{{item.orderArea}}"
            data-servicedate="{{item.serviceDate}}"
            data-totalprice="{{item.totalPrice}}"
            data-grossprice="{{item.grossPrice}}"
            data-earlybirddiscount="{{item.earlyBirdDiscount}}"
            data-newcomerdiscount="{{item.newcomerDiscount}}"
            data-producttype="{{item.productType}}"
            data-isupgraded="{{item.isUpgraded}}"
            data-upgradeprice="{{item.upgradePrice}}">
            <!-- 左：订单名称 -->
            <text class="oi-name">{{item.name}}</text>
            <!-- 中：优惠券预约待联系 → 待确认；其余仍为日期/原字段 -->
            <text class="oi-date" wx:if="{{(item.orderType === 'coupon_booking' || item.orderType === 'gift_service_booking') && item.status === 'pending_contact'}}">待确认</text>
            <text class="oi-date" wx:else>{{item.date}}</text>
            <!-- 右：状态 -->
            <view class="oi-status-col">
              <view class="oi-status-chip {{item.statusClass}}">
                <text class="oi-status-text">{{item.displayStatus || item.status}}</text>
              </view>
            </view>
          </view>
        </scroll-view>

      </view>

      <!-- 无订单 -->
      <view class="empty-block" wx:else>
        <text class="empty-title">暂无订单</text>
        <text class="empty-desc">下单后可在这里查看服务进度和退款状态</text>
      </view>

    </view>

    <!-- ─── 从装修到入住：4步强化链路 ─── -->
    <view class="lifecycle-section-head" wx:if="{{bookingNodes.length === 4}}">
      <text class="lifecycle-section-title">从装修到入住，这 4 步更关键</text>
      <text class="lifecycle-section-sub">{{lifecycleGuideText}}</text>
    </view>

    <view class="booking-section" wx:if="{{bookingNodes.length === 4}}">
      <view class="bc-chain">
        <block wx:for="{{bookingNodes}}" wx:key="label">
          <!-- 链路卡片 -->
          <view class="bc-chain-item bc-chain-item--{{item.entitled ? item.type : 'inactive'}}"
                data-idx="{{index}}"
                bindtap="handleBookingCardTap">
            <!-- 顶行：步骤 + 场景 + 状态 -->
            <view class="bc-chain-head">
              <view class="bc-chain-step {{item.entitled ? 'bc-chain-step--on' : ''}}">{{item.cardStep}}</view>
              <text class="bc-chain-scene">{{item.cardScene}}</text>
              <view class="bc-chain-status bc-chain-status--{{item.entitled ? item.type : 'inactive'}}">
                {{item.entitled ? item.status : '未激活'}}
              </view>
            </view>
            <!-- 服务名 -->
            <text class="bc-chain-name {{!item.entitled ? 'bc-chain-name--dim' : ''}}">{{item.displayLabel}}</text>
            <!-- 图片占位 -->
            <view class="bc-chain-image">
              <text class="bc-chain-image-hint">图片占位</text>
            </view>
            <!-- 痛点/价值文案 -->
            <text class="bc-chain-tagline {{!item.entitled ? 'bc-chain-tagline--dim' : ''}}">{{item.cardTagline}}</text>
            <!-- 注意提示（仅第 1 步未激活） -->
            <view class="bc-chain-warn" wx:if="{{item.warnText}}">
              <view class="bc-chain-warn-mark">
                <text class="bc-chain-warn-mark-text">注意</text>
              </view>
              <text class="bc-chain-warn-text">{{item.warnText}}</text>
            </view>
            <!-- 底部操作行 -->
            <block wx:if="{{item.entitled}}">
              <view class="bc-chain-footer" wx:if="{{item.bookedDate || item.actionText}}">
                <text class="bc-chain-meta" wx:if="{{item.bookedDate}}">已预约 {{item.bookedDate}} {{item.bookedSlot}}</text>
                <view class="bc-chain-btn" wx:if="{{item.actionText}}">
                  <text class="bc-chain-btn-text">{{item.actionText}}</text>
                </view>
              </view>
            </block>
            <block wx:else>
              <view class="bc-chain-inactive-bar {{item.isDepotExpiredCard ? 'bc-chain-inactive-bar--expired' : ''}}">
                <text class="bc-chain-inactive-text">{{item.inactiveFooterText}}</text>
              </view>
            </block>
          </view>
          <!-- 步骤连接线（最后一步不显示） -->
          <view class="bc-chain-connector" wx:if="{{index < 3}}"></view>
        </block>
      </view>
    </view>

    <view class="safe-bottom"></view>
  </view>

  <!-- ─── 升级说明弹层（未激活节点点「点击激活」后展示，深处理不进入）─── -->
  <view class="modal-overlay upgrade-modal-overlay" wx:if="{{showUpgradeModal}}" bindtap="closeUpgradeModal">
    <view class="modal-sheet upgrade-sheet" catchtap="preventBubble">
      <view class="modal-handle"></view>
      <scroll-view class="upgrade-sheet-body" scroll-y="true">
        <view class="upgrade-sheet-head">
          <text class="upgrade-sheet-title">{{upgradeModalNode.label}}</text>
          <text class="upgrade-sheet-pain">{{upgradeModalNode.painShort}}</text>
        </view>
        <view class="upgrade-sheet-gap"></view>
        <view class="upgrade-sheet-divider upgrade-sheet-divider--heavy"></view>
        <block wx:if="{{upgradeOptions.length > 0}}">
          <view class="upgrade-sheet-options">
            <view
              class="upgrade-option {{selectedUpgradeOption === item.id ? 'upgrade-option--selected' : ''}}"
              wx:for="{{upgradeOptions}}"
              wx:key="id"
              data-option-id="{{item.id}}"
              bindtap="selectUpgradeOption">
              <view class="upgrade-row-head">
                <text class="upgrade-option-title">{{item.title}}</text>
                <view class="upgrade-price-group">
                  <text class="upgrade-price-aux" wx:if="{{item.priceAux}}">{{item.priceAux}}</text>
                  <text class="upgrade-price-sep" wx:if="{{item.priceAux}}">·</text>
                  <text class="upgrade-price-main">{{item.priceMain}}</text>
                </view>
              </view>
              <text class="upgrade-value-line">{{item.valueLine}}</text>
            </view>
          </view>
        </block>
        <block wx:elif="{{upgradeModalNode.label === '藏灰处理'}}">
          <text class="upgrade-sheet-expired">当前柜体已进场，已过藏灰处理时点。</text>
        </block>
      </scroll-view>
      <view class="upgrade-sheet-footer">
        <view
          class="modal-btn modal-btn--primary modal-btn--upgrade {{upgradeOptions.length > 0 && selectedUpgradeOption ? '' : 'modal-btn--disabled'}}"
          wx:if="{{upgradeOptions.length > 0}}"
          bindtap="goUpgrade">
          <text class="modal-btn-text">确认升级</text>
        </view>
        <view class="modal-cancel" bindtap="closeUpgradeModal">
          <text class="modal-cancel-text">先不了</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 订单详情入口：先选服务（预约仅日历三项；改期含深处理→人工） -->
  <view class="modal-overlay" wx:if="{{showServicePickerModal}}" bindtap="closeServicePickerModal">
    <view class="modal-sheet" catchtap="preventBubble">
      <view class="modal-handle"></view>
      <view class="modal-body">
        <text class="modal-title">{{servicePickerTitle}}</text>
        <view class="service-picker-list">
          <view
            class="service-picker-row"
            wx:for="{{servicePickerItems}}"
            wx:key="label"
            bindtap="onServicePickerItemTap"
            data-label="{{item.label}}"
            data-kind="{{item.kind}}">
            <text class="service-picker-row-text">{{item.label}}{{item.kind === 'human' ? '（联系客服协调）' : ''}}</text>
            <text class="service-picker-row-arrow">›</text>
          </view>
        </view>
      </view>
      <view class="modal-footer modal-footer--picker">
        <view class="modal-cancel" bindtap="closeServicePickerModal">
          <text class="modal-cancel-text">取消</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ─── 预约时间弹窗 ──────────────────────────────────────────── -->
  <view class="modal-overlay" wx:if="{{showBookingModal}}" bindtap="closeBookingModal">
    <view class="modal-sheet" catchtap="preventBubble">
      <view class="modal-handle"></view>
      <view class="modal-body">
        <text class="modal-title">{{bookingModalNode.label}} · {{bookingModalMode === 'reschedule' ? '改期' : '预约'}}</text>

        <text class="modal-section-label">选择日期</text>

        <!-- 月历：月份导航 -->
        <view class="cal-header">
          <view class="cal-nav" bindtap="prevCalendarMonth">
            <text class="cal-nav-text">‹</text>
          </view>
          <text class="cal-month-label">{{calendarYear}}年{{calendarMonth}}月</text>
          <view class="cal-nav" bindtap="nextCalendarMonth">
            <text class="cal-nav-text">›</text>
          </view>
        </view>

        <!-- 星期表头（一 二 三 四 五 六 日） -->
        <view class="cal-week-head">
          <text class="cal-wh">一</text>
          <text class="cal-wh">二</text>
          <text class="cal-wh">三</text>
          <text class="cal-wh">四</text>
          <text class="cal-wh">五</text>
          <text class="cal-wh">六</text>
          <text class="cal-wh">日</text>
        </view>

        <!-- 日期格子 -->
        <view class="cal-grid">
          <view
            wx:for="{{calendarDays}}"
            wx:key="index"
            class="cal-day {{item.empty ? 'cal-day--empty' : ''}} {{!item.empty && item.disabled ? 'cal-day--disabled' : ''}} {{!item.empty && !item.disabled && item.dateStr === selectedDateStr ? 'cal-day--active' : ''}}"
            bindtap="selectCalendarDate"
            data-datestr="{{item.dateStr}}"
            data-disabled="{{item.disabled}}"
            data-empty="{{item.empty}}">
            <text class="cal-day-text" wx:if="{{!item.empty}}">{{item.day}}</text>
          </view>
        </view>

        <text class="modal-section-label">选择时段</text>
        <view class="slot-row">
          <view class="slot-chip {{selectedSlot === '上午' ? 'slot-chip--active' : ''}}"
            bindtap="selectSlot" data-slot="上午">
            <text class="slot-chip-text">上午</text>
          </view>
          <view class="slot-chip {{selectedSlot === '下午' ? 'slot-chip--active' : ''}}"
            bindtap="selectSlot" data-slot="下午">
            <text class="slot-chip-text">下午</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn modal-btn--primary" bindtap="confirmBooking">
          <text class="modal-btn-text">{{bookingModalMode === 'reschedule' ? '确认改期' : '确认预约'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部固定浮层 -->
  <view class="tabbar">
    <view class="tab-item" bindtap="goIndex">
      <view class="tab-icon"></view>
      <text class="tab-text">开荒</text>
    </view>
    <view class="tab-item" bindtap="goGroupBuyTab">
      <view class="tab-icon"></view>
      <text class="tab-text">我的社区我的团</text>
    </view>
    <view class="tab-item">
      <view class="tab-icon"></view>
      <text class="tab-text active">我的</text>
    </view>
  </view>

</view>
