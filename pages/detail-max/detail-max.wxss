page { background: #f9f9f9; }
.dm-page { min-height: 100vh; background: #f9f9f9; }
.dm-top-bar { background: transparent; }

.dm-hero {
  position: relative;
  width: 100%;
  height: 480rpx;
  overflow: hidden;
}
.dm-hero-bg {
  position: absolute;
  inset: 0;
  background: #e8e8e8;
}
.dm-hero-content {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  bottom: 64rpx;
}
.dm-hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #000000;
  line-height: 62rpx;
}
.dm-hero-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 400;
  color: #999999;
  line-height: 36rpx;
}

.dm-body {
  position: relative;
  margin-top: -32rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #f9f9f9;
  padding: 80rpx 40rpx;
}
.dm-placeholder {
  text-align: center;
  padding: 120rpx 0;
}
.dm-placeholder-text {
  font-size: 28rpx;
  font-weight: 400;
  color: #999999;
}
