.upgrade-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-top: calc(212rpx + env(safe-area-inset-top) + 20rpx);
  padding-bottom: 80rpx;
  box-sizing: border-box;
}

.upgrade-body {
  padding: 20rpx 24rpx;
}

.upgrade-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.upgrade-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111111;
  line-height: 48rpx;
  margin-bottom: 16rpx;
}

.upgrade-desc {
  display: block;
  font-size: 28rpx;
  color: #333333;
  line-height: 44rpx;
  margin-bottom: 12rpx;
}

.upgrade-note {
  display: block;
  font-size: 24rpx;
  color: #888888;
  line-height: 38rpx;
  margin-top: 16rpx;
}

.upgrade-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 24rpx;
  background: #F9E12A;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.upgrade-btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #111111;
}
