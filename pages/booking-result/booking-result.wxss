.result-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-top: calc(212rpx + env(safe-area-inset-top) + 20rpx);
  padding-bottom: 80rpx;
  box-sizing: border-box;
}

.result-body {
  padding: 20rpx 40rpx;
}

.result-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.result-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #F9E12A;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.result-icon {
  font-size: 56rpx;
  font-weight: 600;
  color: #000000;
  line-height: 1;
}

.result-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #000000;
  line-height: 50rpx;
  margin-bottom: 16rpx;
}

.result-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
  line-height: 42rpx;
  text-align: center;
}

.result-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 24rpx;
  background: #F9E12A;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.result-btn-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #000000;
}
