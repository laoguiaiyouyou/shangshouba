/* ================================================================
   group-buy.wxss
   颜色：黄 #f9e12a · 黑 #000000 · 白 #FFFFFF · 灰底 #F2F2F7
   ================================================================ */

page { background: #F2F2F7; }

.gb-page {
  min-height: 100vh;
  background: #F2F2F7;
  box-sizing: border-box;
}

/* 可滚动内容区：
   顶栏黄色部分高度 280rpx + safe-area，再加 16rpx 间距 */
.gb-scroll-body {
  padding-top: calc(296rpx + env(safe-area-inset-top));
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* ── 顶栏：黄色，高度加高以容纳 tab 条 ── */
.global-top-bar {
  background: #f9e12a;
  border-bottom: none;
  /* 在默认 212rpx 基础上再加 68rpx 给 tab 条 */
  height: calc(280rpx + env(safe-area-inset-top));
}

/* brand dot 在黄底上用黑色 */
.global-top-bar .global-brand-dot {
  background: #000000;
}

/* ── 3个内页签：绝对贴底，白色条 ── */
.gb-tabs {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  gap: 0;
  background: #FFFFFF;
  border-top: 1rpx solid rgba(17,17,17,0.08);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.gb-tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  font-weight: 400;
  padding: 18rpx 0;
  position: relative;
}
.gb-tab--active {
  color: #000000;
  font-weight: 500;
}
.gb-tab--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #f9e12a;
  border-radius: 2rpx;
}

/* ── 开团规则：条目列表 ── */
.gb-rule-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F2F2F7;
}
.gb-rule-item:last-child { border-bottom: none; }
.gb-rule-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #000000;
  flex-shrink: 0;
  margin-top: 8rpx;
}
.gb-rule-dot--warning { background: #f9e12a; }
.gb-rule-text {
  font-size: 26rpx;
  color: #333333;
  line-height: 40rpx;
  flex: 1;
}
.gb-rule-text--warning { font-weight: 500; color: #333333; }

/* ── 我的开团：团状态卡 ── */
.gb-team-card {
  background: #111111;
  border-radius: 24rpx;
  margin: 0 40rpx 20rpx;
  padding: 32rpx 28rpx;
}
/* 压矮版：只看进度结论 */
.gb-team-card--compact {
  padding: 28rpx 28rpx 24rpx;
}
.gb-team-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.gb-team-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.gb-team-status-badge {
  font-size: 20rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}
.gb-team-status-badge--recruiting { background: rgba(249,225,42,0.2); color: #f9e12a; }
.gb-team-status-badge--formed     { background: #f9e12a; color: #000000; }
.gb-team-status-badge--expired    { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.4); }

.gb-team-body { }
.gb-team-count-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 16rpx;
}
.gb-team-count-num {
  font-size: 52rpx;
  font-weight: 600;
  color: #f9e12a;
  line-height: 60rpx;
}
.gb-team-count-sep {
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
}
.gb-team-progress-bar {
  height: 10rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.gb-team-progress-fill {
  height: 100%;
  background: #f9e12a;
  border-radius: 5rpx;
  transition: width 0.4s;
}
.gb-team-gap-tip {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  line-height: 36rpx;
}
.gb-team-formed-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.gb-team-formed-icon { font-size: 28rpx; }
.gb-team-formed-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #f9e12a;
}

/* ── Hero ── */
.gb-hero {
  background: #111111;
  margin: 0 40rpx 20rpx;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 36rpx;
}
.gb-hero-tag {
  display: inline-block;
  background: #f9e12a;
  color: #000000;
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  margin-bottom: 20rpx;
}
.gb-hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #FFFFFF;
  line-height: 60rpx;
  letter-spacing: -1rpx;
  margin-bottom: 24rpx;
}
.gb-hero-sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.55);
  margin-top: 12rpx;
  line-height: 36rpx;
}
.gb-community-pill {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}
.gb-community-num {
  font-size: 52rpx;
  font-weight: 600;
  color: #f9e12a;
  line-height: 60rpx;
}
.gb-community-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
}

/* ── 通用卡片 ── */
.gb-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 40rpx 20rpx;
  padding: 28rpx;
  box-sizing: border-box;
}
.gb-card--rule { border: 2rpx solid #f9e12a; }
.gb-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
}
.gb-card-subtitle {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 20rpx;
}
.gb-card-note {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-top: 16rpx;
}
.gb-card-body {
  display: block;
  font-size: 26rpx;
  color: #333333;
  line-height: 42rpx;
}

/* （团购档位样式已移除，改用邻里拼团3户成团模型） */

/* ── 各服务优惠 ── */
.gb-service-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}
.gb-service-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 400;
}
.gb-service-saving {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}
.gb-service-divider {
  height: 1rpx;
  background: #F2F2F7;
}

/* ── 价格表 ── */
.gb-price-table { width: 100%; }
.gb-price-row {
  display: flex;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F2F2F7;
}
.gb-price-row--head .gb-col {
  font-size: 22rpx;
  font-weight: 500;
  color: #999999;
}
.gb-price-row--last { border-bottom: none; }
.gb-col {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
  text-align: center;
}
.gb-col--save { font-weight: 500; }

/* ── 怎么参与（步骤） ── */
.gb-step-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 18rpx;
}
.gb-step-item:last-of-type { margin-bottom: 0; }
.gb-step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #111111;
  color: #f9e12a;
  font-size: 22rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}
.gb-step-text {
  font-size: 26rpx;
  color: #333333;
  line-height: 40rpx;
  flex: 1;
}
.gb-key-rule {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #111111;
  border-radius: 10rpx;
  padding: 14rpx 20rpx;
  margin: 4rpx 0 18rpx;
}
.gb-key-rule-icon { font-size: 26rpx; }
.gb-key-rule-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #f9e12a;
  line-height: 38rpx;
}

/* ── 主动作区：查看团码 + 复制链接 ── */
.gb-action-row {
  display: flex;
  gap: 12rpx;
  margin: 0 40rpx 20rpx;
}
.gb-action-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}
.gb-action-btn--primary {
  background: #111111;
  color: #FFFFFF;
}
.gb-action-btn--ghost {
  background: transparent;
  border: 2rpx solid #C6C6C8;
  color: #333333;
  font-weight: 500;
}

/* ── 主 CTA ── */
.gb-cta {
  margin: 8rpx 40rpx 28rpx;
  height: 96rpx;
  background: #f9e12a;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #000000;
}

/* ── 分段标题 ── */
.gb-section-title {
  font-size: 22rpx;
  font-weight: 500;
  color: #999999;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  padding: 8rpx 40rpx;
}

/* ── 里程碑横轴 ── */
.gb-milestone-row {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
}
.gb-milestone-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.gb-milestone-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #000000;
}
.gb-milestone-dot--gold { background: #f9e12a; }
.gb-milestone-num {
  font-size: 28rpx;
  font-weight: 500;
  color: #000000;
}
.gb-milestone-label {
  font-size: 22rpx;
  color: #999999;
}
.gb-milestone-line {
  flex: 1;
  height: 3rpx;
  background: #E5E5EA;
  margin: 0 12rpx;
  margin-bottom: 30rpx;
}

/* ── 团长权益卡 ── */
.gb-leader-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 40rpx 20rpx;
  padding: 8rpx 0;
}
.gb-leader-tier { padding: 24rpx 28rpx; }
.gb-leader-tier-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.gb-leader-badge {
  background: #F2F2F7;
  color: #000000;
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.gb-leader-badge--gold {
  background: #f9e12a;
  color: #000000;
}
.gb-leader-threshold {
  font-size: 24rpx;
  color: #999999;
}
.gb-leader-benefit {
  display: block;
  font-size: 26rpx;
  color: #333333;
  line-height: 42rpx;
}
.gb-leader-benefit--star {
  font-weight: 500;
  color: #333333;
}
.gb-leader-divider {
  height: 1rpx;
  background: #F2F2F7;
  margin: 0 28rpx;

}

/* ── 数据看板 ── */
.gb-stats-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  margin: 0 40rpx 20rpx;
  padding: 28rpx 24rpx 32rpx;
}
.gb-stats-grid {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}
.gb-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.gb-stat-num {
  font-size: 44rpx;
  font-weight: 600;
  color: #000000;
  line-height: 52rpx;
}
.gb-stat-label {
  font-size: 20rpx;
  color: #999999;
  text-align: center;
}
.gb-stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: #E5E5EA;
}

/* ── 进度条 ── */
.gb-progress-wrap { padding: 0 4rpx; }
.gb-progress-bar {
  height: 12rpx;
  background: #E5E5EA;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
  position: relative;
}
.gb-progress-fill {
  height: 100%;
  background: #f9e12a;
  border-radius: 6rpx;
  transition: width 0.4s;
}
.gb-progress-milestone-mark {
  position: absolute;
  left: 20%;
  top: 0;
  width: 3rpx;
  height: 100%;
  background: #FFFFFF;
  opacity: 0.6;
}
.gb-progress-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.gb-progress-left,
.gb-progress-mid,
.gb-progress-right {
  font-size: 20rpx;
  color: #999999;
}
.gb-progress-hint {
  display: block;
  font-size: 24rpx;
  color: #333333;
  text-align: center;
  margin-top: 8rpx;
}
.gb-progress-hint--mid { color: #333333; }
.gb-progress-hint--done { color: #333333; font-weight: 500; }

/* ── 分享按钮 ── */
.gb-share-btn {
  margin: 0 40rpx 28rpx;
  height: 88rpx;
  border: 2rpx solid #000000;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.gb-bottom-spacer { height: calc(120rpx + env(safe-area-inset-bottom)); }

/* ── 二维码弹窗 ── */
.gb-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}
.gb-modal {
  width: 100%;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}
.gb-modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #000000;
  text-align: center;
  margin-bottom: 8rpx;
}
.gb-modal-sub {
  display: block;
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  margin-bottom: 28rpx;
}
.gb-qr-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  gap: 16rpx;
}
.gb-qr-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #E5E5EA;
  border-top-color: #000000;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.gb-qr-loading-text { font-size: 26rpx; color: #999999; }

/* 团码弹窗 — 未生成态 */
.gb-qr-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
}
.gb-qr-empty-text {
  font-size: 26rpx;
  color: #999999;
}

/* 团码弹窗 — 失败态 */
.gb-qr-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 0 28rpx;
  gap: 10rpx;
}
.gb-qr-error-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}
.gb-qr-error-hint {
  font-size: 22rpx;
  color: #999999;
  text-align: center;
}
.gb-qr-image {
  width: 280rpx;
  height: 280rpx;
  display: block;
  margin: 0 auto 28rpx;
}
.gb-link-box {
  background: #F2F2F7;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}
.gb-link-text {
  font-size: 22rpx;
  color: #333333;
  word-break: break-all;
}
.gb-modal-btn {
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}
.gb-modal-btn--primary { background: #f9e12a; color: #000000; }
.gb-modal-btn--ghost { color: #999999; font-weight: 400; }
/* 去微信分享：<button open-type="share"> 需重置微信默认样式 */
.gb-modal-btn--wechat {
  background: transparent;
  color: #333333;
  font-weight: 500;
  border: 2rpx solid #E5E5EA;
  box-sizing: border-box;
  padding: 0;
  line-height: 88rpx;
}
.gb-modal-btn--wechat::after { border: none; }

/* ── 底部 TabBar ── */
.tabbar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: calc(96rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  display: flex;
  align-items: center;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}
.tab-icon {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #CCCCCC;
}
.tab-icon--active { background: #F9E12A; }
.tab-text {
  font-size: 20rpx;
  font-weight: 400;
  color: #CCCCCC;
  letter-spacing: 0.5rpx;
}
.tab-text.active { color: #000000; font-weight: 500; }

/* ── 我的邀请页专用 ── */
.gb-invite-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 8rpx;
  gap: 20rpx;
}
.gb-invite-empty-text { font-size: 26rpx; color: #999999; }
.gb-cta--sm {
  margin: 0;
  padding: 0 40rpx;
  height: 72rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
}
.gb-qr-area {
  display: flex;
  justify-content: center;
  margin: 20rpx 0;
}
.gb-qr-img-wrap { width: 200rpx; height: 200rpx; }
.gb-qr-image { width: 200rpx; height: 200rpx; }
.gb-qr-image-modal {
  width: 280rpx;
  height: 280rpx;
  display: block;
  margin: 0 auto 28rpx;
}
.gb-qr-placeholder {
  width: 200rpx;
  height: 200rpx;
  background: #F2F2F7;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.gb-qr-placeholder-icon { font-size: 60rpx; }
.gb-qr-placeholder-text { font-size: 22rpx; color: #999999; }
.gb-invite-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 4rpx;
}
.gb-invite-btn {
  height: 80rpx;
  background: #f9e12a;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #000000;
}
.gb-invite-btn--ghost {
  background: transparent;
  border: 2rpx solid #E5E5EA;
  color: #333333;
  font-weight: 500;
}
.gb-stats-row2 {
  padding-top: 12rpx;
  border-top: 1rpx solid #F2F2F7;
  margin-top: 4rpx;
}
.gb-stats-pending-tip { font-size: 22rpx; color: #999999; }
.gb-record-empty { padding: 24rpx 0; text-align: center; }
.gb-record-empty-text { font-size: 26rpx; color: #999999; }
.gb-record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F2F2F7;
}
.gb-record-item:last-child { border-bottom: none; }
.gb-record-left { display: flex; flex-direction: column; gap: 4rpx; }
.gb-record-name { font-size: 26rpx; color: #333333; }
.gb-record-date { font-size: 20rpx; color: #999999; }
.gb-record-status {
  font-size: 22rpx;
  font-weight: 500;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #F2F2F7;
  color: #999999;
}
.gb-record-status--settled   { background: #fffdf0; color: #333333; }
.gb-record-status--finished  { background: #F2F2F7; color: #333333; }
