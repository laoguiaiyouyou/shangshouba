/* ── 团长权益页：S1/S2/S3 分级区块 ── */
.gb-tier-section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 8rpx 40rpx 10rpx;
  padding: 0 4rpx;
}
.gb-tier-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
}
.gb-tier-badge--s1 { background: #E5E5EA; color: #000000; }
.gb-tier-badge--s2 { background: rgba(249,225,42,0.35); color: #000000; }
.gb-tier-badge--s3 { background: #f9e12a; color: #000000; }
.gb-tier-section-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}
.gb-tier-section-unlock {
  margin-left: auto;
  font-size: 22rpx;
  color: #999999;
}
/* S1 完整权益卡 */
.gb-tier-card {
  margin: 0 40rpx 20rpx;
  padding: 24rpx 28rpx 20rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
}
.gb-tier-benefit {
  display: block;
  font-size: 26rpx;
  line-height: 46rpx;
  color: #333333;
}
.gb-tier-detail-btn {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 4rpx;
  margin-top: 14rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F2F2F7;
}
.gb-tier-detail-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
}
.gb-tier-detail-arrow {
  font-size: 28rpx;
  font-weight: 300;
  color: #333333;
  margin-top: -2rpx;
}
/* S2 / S3 轻预告卡 */
.gb-tier-teaser {
  margin: 0 40rpx 16rpx;
  padding: 24rpx 28rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.gb-tier-teaser--s3 {
  border: 2rpx solid rgba(249,225,42,0.5);
  background: rgba(249,225,42,0.05);
  box-sizing: border-box;
}
.gb-tier-teaser-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}
.gb-tier-teaser-body {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}
.gb-tier-teaser-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}
.gb-tier-teaser-hint {
  font-size: 22rpx;
  color: #999999;
}
.gb-tier-teaser-anchor {
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
}
.gb-tier-teaser-arrow {
  font-size: 32rpx;
  font-weight: 300;
  color: #C6C6C8;
  flex-shrink: 0;
}
.gb-tier-teaser-arrow--s3 { color: #333333; }

/* ── 团成员记录 badge 补色 ── */
.gb-record-status--leader  { background: rgba(249,225,42,0.2); color: #333333; font-weight: 500; }

/* ── 累计与返佣：团长进度行 ── */
.gb-stats-leader-row {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F2F2F7;
  margin-top: 4rpx;
}
.gb-stats-gap-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.gb-stats-gap-label {
  font-size: 20rpx;
  color: #999999;
}
.gb-stats-gap-val {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}
.gb-stats-gap-val--done { color: #F9E12A; }
.gb-stats-gap-divider {
  width: 1rpx;
  height: 48rpx;
  background: #E5E5EA;
}

/* ── 团长权益页：权益入口卡片 3列×2行 ── */
.gb-benefit-section {
  margin: 24rpx 40rpx 0;
}
.gb-benefit-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  line-height: 40rpx;
  margin-bottom: 16rpx;
}
/* ── 权益横滑标题栏 ── */
.gb-benefit-tabs {
  display: flex;
  flex-direction: row;
  white-space: nowrap;
  margin-top: 24rpx;
  padding-bottom: 8rpx;
}
.gb-benefit-tab {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 0;
  margin-right: 32rpx;
  flex-shrink: 0;
  background: transparent;
}
.gb-benefit-tab--on {
  background: transparent;
}
.gb-benefit-tab-text {
  font-size: 24rpx;
  font-weight: 400;
  color: #999999;
  white-space: nowrap;
}
.gb-benefit-tab--on .gb-benefit-tab-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #000000;
}

/* ── 权益内容区 ── */
.gb-bc {
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
}
.gb-bc-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.gb-bc-label {
  font-size: 24rpx;
  font-weight: 400;
  color: #999999;
}
.gb-bc-badge {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.gb-bc-badge--normal { background: #f3f3f3; }
.gb-bc-badge--trial  { background: #F9E12A; }
.gb-bc-badge--senior { background: #F9E12A; }
.gb-bc-badge--honor  { background: #F9E12A; }
.gb-bc-badge-text {
  font-size: 20rpx;
  font-weight: 500;
  color: #000000;
}
.gb-bc-badge--normal .gb-bc-badge-text {
  color: #999999;
}

/* 月月领券列表 */
.gb-bc-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.gb-bc-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}
.gb-bc-row + .gb-bc-row {
  border-top: 1rpx solid #f3f3f3;
}
.gb-bc-row-name {
  font-size: 26rpx;
  font-weight: 400;
  color: #333333;
  flex: 1;
}
.gb-bc-btn {
  padding: 6rpx 24rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.gb-bc-btn--claim {
  background: #F9E12A;
}
.gb-bc-btn--done {
  background: #f3f3f3;
}
.gb-bc-btn-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #000000;
}
.gb-bc-btn-text--muted {
  color: #CCCCCC;
}

/* 券型权益额度 */
.gb-bc-quota {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  line-height: 44rpx;
  margin-bottom: 20rpx;
}

/* 原价说明 */
.gb-bc-original {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 20rpx;
  padding: 12rpx 16rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
}
.gb-bc-section-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #000000;
  margin-bottom: 16rpx;
}

/* 三档对比 */
.gb-bc-tiers {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.gb-bc-tier {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #F5F5F5;
}
.gb-bc-tier-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}
.gb-bc-tier-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}
.gb-bc-tier-level {
  font-size: 24rpx;
  font-weight: 600;
  color: #000000;
}
.gb-bc-tier-freq {
  font-size: 22rpx;
  color: #999999;
}
.gb-bc-tier-price {
  font-size: 26rpx;
  color: #000000;
  font-weight: 600;
}
.gb-bc-tier-tag {
  font-size: 20rpx;
  font-weight: 500;
  color: #000000;
  background: #F9E12A;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

/* 状态行 */
.gb-bc-status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}
.gb-bc-status-row + .gb-bc-status-row {
  border-top: 1rpx solid #f3f3f3;
}
.gb-bc-status-label {
  font-size: 24rpx;
  font-weight: 400;
  color: #999999;
}
.gb-bc-status-val {
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
}
.gb-bc-detail-rows {
  margin-bottom: 16rpx;
}

/* 规则说明 */
.gb-bc-rules {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f3f3f3;
}
.gb-bc-rules-title {
  display: block;
  font-size: 24rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
}
.gb-bc-rules-text {
  display: block;
  font-size: 22rpx;
  font-weight: 400;
  color: #999999;
  line-height: 36rpx;
}

/* ══ 开团弹窗：遮罩 + Sheet 平级结构（防 input tap 穿透）══ */

/* 遮罩：全屏半透明，z-index 低于 sheet */
.gc-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 900;
}

/* Sheet：底部弹出，z-index 高于遮罩，独立层不影响遮罩点击 */
.gc-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 901;
  background: #FFFFFF;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  max-height: 85vh;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}

.gc-sheet-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #000000;
  text-align: center;
  margin-bottom: 8rpx;
  width: 100%;
}
.gc-sheet-sub {
  display: block;
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  line-height: 36rpx;
  margin-bottom: 28rpx;
  width: 100%;
}

/* 表单字段组 */
.gc-field-group {
  width: 100%;
  margin-bottom: 20rpx;
}
.gc-field-label-row {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 10rpx;
}
.gc-field-label-row--with-unit {
  justify-content: space-between;
}
.gc-field-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}
.gc-field-required {
  font-size: 24rpx;
  color: #000000;
}
/* 字段行内辅助提示，如"无单元请填 1" */
.gc-field-hint {
  margin-left: 10rpx;
  font-size: 20rpx;
  color: #999999;
  font-weight: 400;
}
.gc-field-unit {
  font-size: 24rpx;
  color: #999999;
}
.gc-field-input {
  width: 100%;
  height: 88rpx;
  background: #F2F2F7;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333333;
}

/* ── 房屋类型横排按钮组 ── */
.gc-house-type-row {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}
.gc-house-type-btn {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  background: #F5F5F5;
  font-size: 24rpx;
  font-weight: 400;
  color: #333333;
}
.gc-house-type-btn--active {
  background: #111111;
  color: #FFFFFF;
  font-weight: 500;
}

/* ── 结构化楼栋房号输入 ── */
.gc-room-row {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}
.gc-room-col {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}
.gc-room-input {
  flex: 1;
  height: 88rpx;
  background: #F2F2F7;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  font-weight: 400;
  color: #333333;
  min-width: 0;
}
.gc-room-suffix {
  font-size: 24rpx;
  font-weight: 400;
  color: #999999;
  flex-shrink: 0;
}

/* 提交按钮 */
.gc-submit-btn {
  width: 100%;
  height: 96rpx;
  background: #f9e12a;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #000000;
  margin-top: 8rpx;
  margin-bottom: 12rpx;
}
.gc-submit-btn--disabled {
  background: #E5E5EA;
  color: rgba(17,17,17,0.35);
}

/* 取消 / 次要按钮 */
.gc-cancel-btn {
  width: 100%;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

/* QR 成功区 */
.gc-qr-area {
  width: 240rpx;
  height: 240rpx;
  background: #F2F2F7;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 12rpx auto 24rpx;
  overflow: hidden;
}
.gc-qr-img-wrap { width: 100%; height: 100%; }
.gc-qr-image    { width: 100%; height: 100%; }
.gc-qr-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.gc-qr-hint { font-size: 22rpx; color: #999999; }

/* 成功标签 */
.gc-success-tag {
  background: rgba(249,225,42,0.12);
  color: #F9E12A;
  font-size: 24rpx;
  font-weight: 500;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
  align-self: center;
}
