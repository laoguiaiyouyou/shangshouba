.dt-page { padding: 32rpx; background: #f5f5f5; min-height: 100vh; box-sizing: border-box; }
.dt-header { margin-bottom: 32rpx; }
.dt-title { display: block; font-size: 36rpx; font-weight: 600; color: #000000; }
.dt-sub { display: block; font-size: 22rpx; color: #999999; margin-top: 4rpx; }
.dt-section { margin-bottom: 32rpx; }
.dt-section-title { display: block; font-size: 24rpx; font-weight: 500; color: #666666; margin-bottom: 12rpx; }
.dt-row { display: flex; gap: 12rpx; }
.dt-btn {
  display: flex; align-items: center; justify-content: center;
  height: 80rpx; border-radius: 16rpx; margin-bottom: 12rpx; flex: 1;
}
.dt-btn--yellow { background: #F9E12A; }
.dt-btn--dark { background: #111111; }
.dt-btn--outline { background: #FFFFFF; border: 1rpx solid #E8E8E8; }
.dt-btn--danger { background: #FFFFFF; border: 1rpx solid #333333; }
.dt-btn-text { font-size: 26rpx; font-weight: 500; color: #000000; }
.dt-btn-text--white { color: #FFFFFF; }
.dt-log {
  background: #111111; border-radius: 16rpx; padding: 20rpx;
  margin-top: 24rpx; max-height: 400rpx; overflow-y: auto;
}
.dt-log-title { display: block; font-size: 22rpx; color: #F9E12A; font-weight: 500; margin-bottom: 12rpx; }
.dt-log-line { display: block; font-size: 20rpx; color: rgba(255,255,255,0.6); line-height: 32rpx; }
