/* ================================================================
   首页 — Pristine Canvas · 轻量呼吸感
   Surface:  #f9f9f9 / #ffffff / #f3f3f3
   Accent:   #F9E12A（仅 CTA / 标签）
   Text:     #000 (H1=600) / #333 (body=400) / #999 (caption)
   Spacing:  模块间 64rpx，卡片内 32rpx，侧边距 40rpx
   ================================================================ */

page { background: #f9f9f9; }

.page {
  min-height: 100vh;
  background: #f9f9f9;
}

.page .global-top-bar { display: none; }

/* ── 顶栏 ──────────────────────────────────── */
.top-bar {
  position: fixed;
  left: 0; right: 0; top: 0;
  z-index: 100;
  height: calc(88rpx + env(safe-area-inset-top));
  padding-top: env(safe-area-inset-top);
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.top-bar-brand {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.top-bar-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 8rpx;
  background: #F3F3F3;
  border: 1rpx solid #EAEAEA;
  box-sizing: border-box;
}

.top-bar-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #000000;
  letter-spacing: 0.5rpx;
}

/* ── Hero ───────────────────────────────────── */
.hero {
  position: relative;
  width: 100%;
  height: 1000rpx;
  overflow: hidden;
}

.hero-photo {
  position: absolute;
  inset: 0;
  background: #E8E8E8;
}

.hero-photo-img {
  width: 100%;
  height: 100%;
}

.hero-photo-scrim {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(249,249,249,0) 0%, rgba(249,249,249,0) 62%, rgba(249,249,249,0.3) 78%, rgba(249,249,249,0.88) 94%, #f9f9f9 100%);
}

.hero-overlay {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  bottom: 128rpx;
}

.hero-title {
  display: block;
  font-size: 52rpx;
  font-weight: 600;
  color: #000000;
  line-height: 72rpx;
  letter-spacing: -1rpx;
  white-space: pre-line;
}

.hero-sub {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  font-weight: 400;
  color: #555555;
  line-height: 38rpx;
}

/* 数字条：紧贴标题下方 */
.hero-stats {
  position: absolute;
  left: 48rpx;
  right: 48rpx;
  bottom: 36rpx;
  display: flex;
  align-items: flex-end;
  gap: 44rpx;
}

.hero-stat {
  display: flex;
  flex-direction: column;
}

.hero-stat-val {
  font-size: 38rpx;
  font-weight: 600;
  color: #000000;
  line-height: 46rpx;
  letter-spacing: -0.5rpx;
}

.hero-stat-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  font-weight: 400;
  color: #888888;
  letter-spacing: 1rpx;
}

/* ── 内容区 ─────────────────────────────────── */
.content {
  position: relative;
  margin-top: -16rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #f9f9f9;
  padding: 4rpx 40rpx 0;
  box-shadow: 0 -12rpx 32rpx rgba(0, 0, 0, 0.04);
}

/* ── 服务区 ─────────────────────────────────── */
.svc-section {
  margin-bottom: 0;
}

.svc-main {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx 32rpx 24rpx;
  border: 1rpx solid #ECECEC;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.svc-main-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.svc-hot-tag {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #F9E12A;
  font-size: 20rpx;
  font-weight: 600;
  color: #000000;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.svc-main-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  line-height: 44rpx;
  letter-spacing: -0.3rpx;
}

.svc-main-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: #F3F3F3;
  border: 1rpx solid #EAEAEA;
  box-sizing: border-box;
  flex-shrink: 0;
}

.svc-main-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 400;
  color: #666666;
  line-height: 38rpx;
}

/* 副卡 */
.svc-pair {
  display: flex;
  gap: 16rpx;
  margin-top: 6rpx;
}

.svc-sub {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 22rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  border: 1rpx solid #ECECEC;
  box-sizing: border-box;
}

.svc-sub-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: #F3F3F3;
  border: 1rpx solid #EAEAEA;
  box-sizing: border-box;
  margin-bottom: 10rpx;
}

.svc-sub-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
  line-height: 36rpx;
}

.svc-sub-desc {
  margin-top: 4rpx;
  font-size: 22rpx;
  font-weight: 400;
  color: #777777;
  line-height: 34rpx;
}

/* ── 团购 CTA ──────────────────────────────── */
.group-cta {
  margin-top: 8rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #F9E12A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
  letter-spacing: 0.5rpx;
}

/* ── 通用标题 ──────────────────────────────── */
.section-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  line-height: 44rpx;
  letter-spacing: -0.3rpx;
}

.section-meta {
  font-size: 18rpx;
  font-weight: 400;
  color: #AAAAAA;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* ── 品质保障 ──────────────────────────────── */
.quality-section {
  margin-top: 48rpx;
}

.quality-grid {
  display: flex;
  gap: 12rpx;
  height: 420rpx;
}

.quality-cell {
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
}

.quality-cell--tall {
  flex: 1;
  height: 100%;
}

.quality-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.quality-cell--half {
  flex: 1;
}

/* 照片容器空态：未来放真实照片时结构不变 */
.quality-photo {
  width: 100%;
  height: 100%;
  position: relative;
  background:
    url("data:image/svg+xml;charset=utf-8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 120 80'><circle cx='86' cy='22' r='7' fill='%23bebebe'/><polygon points='8,66 40,28 70,66' fill='%23bebebe'/><polygon points='48,66 74,38 108,66' fill='%23a8a8a8'/></svg>") center / 52% auto no-repeat,
    linear-gradient(180deg, #F0F0F0 0%, #E2E2E2 100%);
  border: 1rpx solid #D8D8D8;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  box-sizing: border-box;
}

.quality-photo::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 55%, rgba(0, 0, 0, 0.10) 100%);
  pointer-events: none;
}

.quality-photo::after {
  content: '照片位';
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  font-size: 18rpx;
  color: #888888;
  letter-spacing: 1rpx;
}

.quality-label {
  position: absolute;
  left: 16rpx;
  bottom: 16rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #F9E12A;
  font-size: 22rpx;
  font-weight: 600;
  color: #000000;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.12);
  z-index: 2;
}

/* ── 评价 ──────────────────────────────────── */
.review-block {
  margin-top: 64rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #ECECEC;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.review-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.review-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #000000;
  letter-spacing: -0.2rpx;
}

.review-pill {
  display: flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: #F9E12A;
  gap: 6rpx;
  box-shadow: 0 4rpx 12rpx rgba(249, 225, 42, 0.35);
}

.review-score {
  font-size: 24rpx;
  font-weight: 500;
  color: #000000;
}

.review-label {
  font-size: 20rpx;
  font-weight: 400;
  color: #000000;
}

.review-count {
  font-size: 18rpx;
  color: rgba(0, 0, 0, 0.55);
}

.review-arrow {
  font-size: 22rpx;
  color: #000000;
  opacity: 0.4;
}

.review-body {
  display: flex;
  align-items: flex-start;
  margin-top: 24rpx;
  gap: 16rpx;
}

.review-bar {
  flex-shrink: 0;
  width: 3rpx;
  height: 72rpx;
  margin-top: 6rpx;
  border-radius: 2rpx;
  background: #F9E12A;
}

.review-snippet {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  font-weight: 400;
  line-height: 42rpx;
  color: #555555;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* ── 为什么选我们 ──────────────────────────── */
.why-section {
  margin-top: 72rpx;
}

.why-cards {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.why-card-lg {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid #ECECEC;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

/* 照片容器空态：未来放真实照片时结构不变 */
.why-card-img {
  width: 100%;
  height: 340rpx;
  position: relative;
  background:
    url("data:image/svg+xml;charset=utf-8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 80'><circle cx='124' cy='22' r='8' fill='%23bebebe'/><polygon points='8,68 46,26 84,68' fill='%23bebebe'/><polygon points='60,68 94,36 136,68' fill='%23a8a8a8'/></svg>") center / 42% auto no-repeat,
    linear-gradient(180deg, #F0F0F0 0%, #E2E2E2 100%);
  border-bottom: 1rpx solid #E8E8E8;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  box-sizing: border-box;
}

/* 奇偶节奏差：2、4 张图片位底色浅一档，避免 4 连贯等权重 */
.why-card-lg:nth-child(even) .why-card-img {
  background:
    url("data:image/svg+xml;charset=utf-8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 80'><circle cx='124' cy='22' r='8' fill='%23cccccc'/><polygon points='8,68 46,26 84,68' fill='%23cccccc'/><polygon points='60,68 94,36 136,68' fill='%23b8b8b8'/></svg>") center / 42% auto no-repeat,
    linear-gradient(180deg, #F5F5F5 0%, #ECECEC 100%);
}

.why-card-img::after {
  content: '照片位';
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  font-size: 20rpx;
  color: #888888;
  letter-spacing: 1rpx;
}

.why-card-body {
  padding: 28rpx 28rpx 32rpx;
}

.why-card-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
  line-height: 40rpx;
  letter-spacing: -0.2rpx;
}

.why-card-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 400;
  color: #666666;
  line-height: 40rpx;
}

/* ── 底部留白 ──────────────────────────────── */
.bottom-spacer {
  height: calc(64rpx + env(safe-area-inset-bottom) + 96rpx);
}

/* ── TabBar ────────────────────────────────── */
.tabbar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  height: calc(96rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid #EEEEEE;
  display: flex;
  align-items: center;
  justify-content: space-around;
  z-index: 999;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3rpx;
}

.tab-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #D4D4D4;
}

.tab-dot--on {
  width: 8rpx;
  height: 8rpx;
  background: #F9E12A;
}

.tab-label {
  font-size: 20rpx;
  font-weight: 400;
  color: #BBBBBB;
  letter-spacing: 0.3rpx;
}

.tab-label--on {
  color: #000000;
  font-weight: 500;
}
