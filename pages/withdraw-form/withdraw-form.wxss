.wf-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-top: calc(212rpx + env(safe-area-inset-top) + 20rpx);
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* =============================
   通用卡片
============================= */
.wf-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin: 48rpx 40rpx 0;
  padding: 28rpx 28rpx;
  box-sizing: border-box;
}

.card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #000000;
  line-height: 36rpx;
  margin-bottom: 20rpx;
}

/* =============================
   提现金额卡
============================= */
.amount-input-row {
  display: flex;
  align-items: center;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
}

.amount-symbol {
  font-size: 40rpx;
  font-weight: 600;
  color: #000000;
  margin-right: 8rpx;
  line-height: 1;
}

.amount-input {
  flex: 1;
  font-size: 40rpx;
  font-weight: 600;
  color: #000000;
  line-height: 56rpx;
  border: none;
  background: transparent;
}

.amount-placeholder {
  color: #cccccc;
  font-size: 36rpx;
  font-weight: 400;
}

.amount-tips {
  display: flex;
  justify-content: flex-end;
}

.amount-tip-item {
  font-size: 24rpx;
  color: #F9E12A;
  line-height: 34rpx;
}

/* =============================
   到账方式卡
============================= */
.method-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
}

.method-item.selected {
  background: #fffbe6;
  padding: 16rpx;
  margin: -8rpx;
}

.method-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.wechat-icon {
  background: #F9E12A;
}

.method-icon-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #ffffff;
}

.method-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.method-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  line-height: 40rpx;
}

.method-desc {
  font-size: 22rpx;
  color: #999999;
  line-height: 34rpx;
}

.method-check {
  font-size: 28rpx;
  color: #F9E12A;
  font-weight: 500;
  flex-shrink: 0;
}

/* =============================
   提现说明卡
============================= */
.notice-item {
  display: block;
  font-size: 24rpx;
  color: #999999;
  line-height: 40rpx;
}

/* =============================
   提交按钮
============================= */
.wf-submit-wrap {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.wf-submit-btn {
  display: block;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #F9E12A;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #000000;
}

/* =============================
   确认弹窗
============================= */
.wf-modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.wf-modal {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #000000;
  line-height: 42rpx;
  margin-bottom: 24rpx;
}

.modal-amount {
  font-size: 64rpx;
  font-weight: 600;
  color: #000000;
  line-height: 80rpx;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 24rpx;
  color: #999999;
  line-height: 36rpx;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #999999;
}

.modal-btn.confirm {
  background: #F9E12A;
  color: #000000;
}
