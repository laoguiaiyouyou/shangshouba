<wxs module="fmt">
function formatDate(str) {
  if (!str) return '';
  var parts = str.split(' ')[0].split('-');
  if (parts.length >= 3) {
    var year = parts[0].slice(-2);
    return year + '-' + parts[1] + '-' + parts[2];
  }
  return str;
}
module.exports = { formatDate: formatDate };
</wxs>

<view class="withdraw-page">

  <view class="global-top-bar">
    <view class="global-top-back" bindtap="goBack">
      <text class="global-top-back-icon">‹</text>
    </view>
    <view class="global-brand-wrap">
      <view class="global-brand-dot"></view>
      <text class="global-brand-title">安心住·上手吧</text>
    </view>
    <view class="global-top-capsule"></view>
  </view>

  <!-- 提现模块 ~45% -->
  <view class="withdraw-section">
    <!-- 可提现余额卡（含右侧立即提现按钮） -->
    <view class="withdraw-card withdraw-balance-card">
      <view class="withdraw-balance-left">
        <text class="balance-value">¥{{withdrawableAmount}}</text>
        <text class="balance-label">可提现</text>
      </view>
      <view class="withdraw-action-box" bindtap="handleWithdraw">
        <text class="withdraw-action-text">立即提现</text>
      </view>
    </view>

    <!-- 数据统计卡 -->
    <view class="withdraw-card stats-card">
      <view class="stats-item">
        <text class="stats-value">¥680</text>
        <text class="stats-label">累计获得返现</text>
      </view>
      <view class="stats-divider"></view>
      <view class="stats-item">
        <text class="stats-value">¥240</text>
        <text class="stats-label">累计福利价值</text>
      </view>
    </view>

    <!-- 提现记录卡片 -->
    <view class="withdraw-record-card">
      <scroll-view class="withdraw-record-scroll" scroll-y="true">
        <view class="withdraw-record-row" wx:for="{{withdrawRecords}}" wx:key="index">
          <text class="withdraw-col-type">转介绍</text>
          <text class="withdraw-col-date">{{item.date}}</text>
          <text class="withdraw-col-amount">{{item.amount}}</text>
          <text class="withdraw-col-status status-arrived" wx:if="{{item.status === '已到账'}}">已到账</text>
          <text class="withdraw-col-status status-processing-text" wx:elif="{{item.status === '处理中'}}">处理中</text>
          <text class="withdraw-col-status status-other" wx:else>{{item.status}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 我的退款模块（独立区块） -->
  <view class="refund-section">
    <view class="refund-divider"></view>
    <text class="refund-section-title refund-section-title-center">我的退款</text>
    <view class="refund-list" wx:if="{{refundList.length > 0}}">
      <view class="refund-row" wx:for="{{refundList}}" wx:key="index">
        <text class="refund-name">{{item.name}}</text>
        <text class="refund-date">{{item.date}}</text>
        <text class="refund-amount">{{item.amount}}</text>
        <text class="refund-status {{item.status === '已退款' ? 'status-done' : 'status-processing'}}">{{item.status}}</text>
      </view>
    </view>
    <view class="empty-block" wx:else>
      <text class="empty-title">暂无退款记录</text>
      <text class="empty-desc">提交退款申请后，可在这里查看退款进度</text>
    </view>
  </view>

  <!-- 遮罩 -->
  <view wx:if="{{showWithdrawModal}}" class="withdraw-mask" bindtap="closeWithdrawModal"></view>

  <!-- 底部弹窗 -->
  <view wx:if="{{showWithdrawModal}}" class="withdraw-modal">
    <view class="withdraw-modal-handle"></view>
    <text class="withdraw-modal-title">确认提现</text>

    <view class="withdraw-modal-amount-card">
      <text class="withdraw-modal-amount-label">提现金额</text>
      <text class="withdraw-modal-amount">¥320</text>
    </view>

    <view class="withdraw-modal-row">
      <text class="withdraw-modal-row-label">提现方式</text>
      <text class="withdraw-modal-row-value">原路退回</text>
    </view>

    <view class="withdraw-modal-row">
      <text class="withdraw-modal-row-label">预计到账</text>
      <text class="withdraw-modal-row-value">24 小时内</text>
    </view>

    <text class="withdraw-modal-confirm-btn" bindtap="confirmWithdraw">确认提现 ¥320</text>
    <text class="withdraw-modal-cancel" bindtap="closeWithdrawModal">取消</text>
  </view>

</view>
