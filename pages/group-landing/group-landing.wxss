/* =============================
   页面基础
============================= */
.gl-page {
  min-height: 100vh;
  background: #F2F2F7;
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* =============================
   顶部导航
============================= */
.gl-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(env(safe-area-inset-top) + 20rpx) 40rpx 16rpx;
  background: #F2F2F7;
}

.gl-nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gl-nav-back-icon {
  font-size: 52rpx;
  color: #000000;
  font-weight: 300;
  line-height: 1;
}

.gl-nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #000000;
}

.gl-nav-placeholder {
  width: 64rpx;
}

/* =============================
   加载 / 错误 居中态
============================= */
.gl-center-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  gap: 20rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.gl-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 5rpx solid #E5E5EA;
  border-top-color: #111111;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.gl-center-hint {
  font-size: 26rpx;
  color: #999999;
}

.gl-error-emoji {
  font-size: 72rpx;
}

.gl-error-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #000000;
}

.gl-error-hint {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
}

.gl-ghost-btn {
  margin-top: 8rpx;
  padding: 18rpx 40rpx;
  background: rgba(17, 17, 17, 0.06);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

/* =============================
   上半部分：团规则 Hero
============================= */
.gl-hero {
  margin: 0 40rpx 56rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 0;
  overflow: hidden;
}

/* 社区头部 */
.gl-hero-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.gl-hero-tag {
  flex-shrink: 0;
  background: #111111;
  color: #F9E12A;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.gl-hero-community {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

/* 核心规则三列 */
.gl-rule-row {
  display: flex;
  align-items: stretch;
  background: #F9F9F9;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.gl-rule-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 8rpx;
  gap: 6rpx;
}

.gl-rule-divider {
  width: 1rpx;
  background: #E5E5EA;
  margin: 14rpx 0;
}

.gl-rule-num {
  font-size: 30rpx;
  font-weight: 600;
  color: #000000;
  line-height: 1.4;
}

.gl-rule-label {
  font-size: 20rpx;
  color: #999999;
  line-height: 1.5;
}

/* =============================
   当前团进度卡
============================= */
.gl-progress-card {
  background: #F9F9F9;
  border-radius: 0 0 20rpx 20rpx;
  padding: 20rpx 0 24rpx;
  margin: 0 -28rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  border-top: 1rpx solid #F2F2F7;
}

.gl-progress-card--formed {
  background: rgba(17, 17, 17, 0.03);
}

/* 成团行 */
.gl-formed-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 4rpx 0;
}

.gl-formed-icon {
  font-size: 36rpx;
}

.gl-formed-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  flex: 1;
}

/* 进度差距行 */
.gl-gap-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.gl-gap-pre {
  font-size: 24rpx;
  color: #999999;
}

.gl-gap-num {
  font-size: 48rpx;
  font-weight: 600;
  color: #000000;
  line-height: 1;
}

.gl-gap-suf {
  font-size: 24rpx;
  color: #999999;
}

/* 进度条 */
.gl-progress-track {
  height: 10rpx;
  background: #E5E5EA;
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.gl-progress-fill {
  height: 100%;
  background: #F9E12A;
  border-radius: 999rpx;
  transition: width 0.4s ease;
}

/* 成员槽 */
.gl-slots {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.gl-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.gl-slot--joined {
  opacity: 1;
}

.gl-slot--empty {
  opacity: 1;
}

.gl-slot-initial {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #111111;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 72rpx;
}

.gl-slot-plus {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #E5E5EA;
  border: 2rpx dashed #C7C7CC;
  color: #C7C7CC;
  font-size: 36rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 72rpx;
}

.gl-slot-name {
  font-size: 20rpx;
  color: #999999;
}

.gl-slot-name--empty {
  color: #C7C7CC;
}

/* 倒计时 */
.gl-expire {
  background: rgba(249, 225, 42, 0.12);
  border-radius: 10rpx;
  padding: 10rpx 14rpx;
  display: inline-flex;
}

.gl-expire-text {
  font-size: 22rpx;
  color: #F9E12A;
}

/* 过期 */
.gl-expired-row {
  padding: 8rpx 0;
}

.gl-expired-text {
  font-size: 26rpx;
  color: #999999;
}

/* =============================
   下半部分：服务选择区
============================= */
.gl-services-section {
  margin: 0 40rpx;
}

.gl-services-head {
  padding: 4rpx 0 16rpx;
}

.gl-services-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 6rpx;
}

.gl-services-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(17, 17, 17, 0.40);
}

/* 服务卡列表 */
.gl-service-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 单张服务卡 */
.gl-service-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  position: relative;
  overflow: hidden;
}

/* 卡头 */
/* 卡头：左侧名称区 + 右上角CTA */
.gl-sc-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.gl-sc-head-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.gl-sc-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  line-height: 1.4;
}

.gl-sc-badge {
  background: #F9E12A;
  border-radius: 999rpx;
  padding: 3rpx 14rpx;
  align-self: flex-start;
}

.gl-sc-badge-text {
  font-size: 18rpx;
  font-weight: 500;
  color: #000000;
}

/* 右上角轻量 CTA 胶囊 */
.gl-sc-cta {
  flex-shrink: 0;
  background: #111111;
  border-radius: 999rpx;
  padding: 10rpx 20rpx;
}

.gl-sc-cta--disabled {
  background: #E5E5EA;
}

.gl-sc-cta-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #FFFFFF;
  white-space: nowrap;
}

.gl-sc-cta--disabled .gl-sc-cta-text {
  color: #999999;
}

/* 场景标签 */
.gl-sc-scene {
  display: block;
  font-size: 20rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

/* 核心价值文案 */
.gl-sc-tagline {
  display: block;
  font-size: 24rpx;
  color: rgba(17, 17, 17, 0.55);
  line-height: 1.5;
}

/* =============================
   底部说明
============================= */
.gl-footer {
  padding: 24rpx 40rpx 0;
}

.gl-footer-text {
  display: block;
  font-size: 20rpx;
  color: rgba(17, 17, 17, 0.28);
  text-align: center;
  line-height: 1.7;
}
